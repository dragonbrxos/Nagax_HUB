            b.TextColor3 = C.white
            b.TextSize = 11
            b.Font = Enum.Font.GothamBold
            b.AutoButtonColor = false
            b.Parent = row
            Utils.Corner(b, 6)
            b.MouseButton1Click:Connect(function()
                if callback then pcall(callback) end
            end)
            return {Button = b, Row = row, Method = "SeaFallback"}
        end
        
        return result
    end
    
    -- TOGGLE SEA
    function tabObj:SeaToggle(labelText, default, callback)
        return self:Toggle(labelText, default, callback, {
            onColor = C.seaBlue,
            offColor = C.off,
