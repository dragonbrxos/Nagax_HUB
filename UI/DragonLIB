-- TAB ESPECIAL: SEA EVENT (MAR) - ULTRA ROBUSTA
-- ═══════════════════════════════════════════════════════════════════════════════
function DragonLib:CreateSeaEventTab()
    local tabName = "🌊 Mar Event"
    
    -- Verificar se já existe
    for _, t in ipairs(tabs) do
        if t._btn.Text == tabName then return t end
    end
    
    DebugLog:Log("INFO", "Criando Sea Event Tab com sistema ultra robusto")
    
    local btn = Instance.new("TextButton")
    btn.Name = "SeaEventBtn"
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = C.bg3
    btn.BorderSizePixel = 0
    btn.Text = tabName
    btn.TextColor3 = C.seaBlue
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false
    btn.LayoutOrder = #tabs + 1
    btn.Parent = sidebar
    Utils.Corner(btn, 8)
    
    local seaStroke = Utils.Stroke(btn, 1, C.seaBlue, 0.5)
    
    local btnPad = Instance.new("UIPadding")
    btnPad.PaddingLeft = UDim.new(0, 12)
    btnPad.Parent = btn
    
    btn.MouseEnter:Connect(function()
        if not (activeTab and activeTab._btn == btn) then
            Utils.Tween(btn, {BackgroundColor3 = C.bg4})
            if seaStroke then seaStroke.Transparency = 0.3 end
        end
    end)
    btn.MouseLeave:Connect(function()
        if not (activeTab and activeTab._btn == btn) then
            Utils.Tween(btn, {BackgroundColor3 = C.bg3})
            if seaStroke then seaStroke.Transparency = 0.5 end
        end
    end)
    
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name = "Scroll_SeaEvent"
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = C.seaBlue
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.ElasticBehavior = Enum.ElasticBehavior.Never
    scroll.Visible = false
    scroll.Parent = mainPanel
    
    Utils.Padding(scroll, 10, 10, 10, 10)
    Utils.ListLayout(scroll, Enum.FillDirection.Vertical, 6, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Top)
    
    local tabObj = {
        _btn = btn,
        _scroll = scroll,
        _order = 0,
        _btnColor = C.bg3,
        _txtColor = C.seaBlue,
        _activeColor = C.seaBlue,
        _type = "SeaEvent"
    }
    
    function tabObj:NextOrder()
        self._order = self._order + 1
        return self._order
    end
    
    function tabObj:MakeRow(h, transparent)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, h or 36)
