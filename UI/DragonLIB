-- UTILITÁRIOS BASE
-- ═══════════════════════════════════════════════════════════════════════════════
local Utils = {}

function Utils.Corner(p, r)
    local success, result = pcall(function()
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, r or 6)
        c.Parent = p
        return c
    end)
    return success and result or nil
end

function Utils.Stroke(p, thick, col, transp)
    local success, result = pcall(function()
        local s = Instance.new("UIStroke")
        s.Thickness = thick or 1
        s.Color = col or C.bdr
        s.Transparency = transp or 0
        s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        s.Parent = p
        return s
    end)
    return success and result or nil
end

function Utils.Tween(obj, props, t)
    local success = pcall(function()
        if not obj or not obj.Parent then return end
        ts:Create(obj, TweenInfo.new(t or 0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
    end)
    return success
end

function Utils.Label(parent, txt, size, col, weight, xalign)
    local success, result = pcall(function()
        local l = Instance.new("TextLabel")
        l.Size = UDim2.new(1,0,1,0)
        l.BackgroundTransparency = 1
        l.Text = txt or ""
        l.TextSize = size or 12
        l.Font = weight == "bold" and Enum.Font.GothamBold or Enum.Font.Gotham
        l.TextColor3 = col or C.txt
        l.TextXAlignment = xalign or Enum.TextXAlignment.Left
        l.TextWrapped = true
        l.Parent = parent
        return l
    end)
    return success and result or nil
end

function Utils.Padding(parent, top, bottom, left, right)
    local success, result = pcall(function()
        local p = Instance.new("UIPadding")
        p.PaddingTop = UDim.new(0, top or 0)
        p.PaddingBottom = UDim.new(0, bottom or 0)
        p.PaddingLeft = UDim.new(0, left or 0)
        p.PaddingRight = UDim.new(0, right or 0)
        p.Parent = parent
        return p
    end)
    return success and result or nil
end

function Utils.ListLayout(parent, direction, padding, halign, valign)
    local success, result = pcall(function()
        local l = Instance.new("UIListLayout")
        l.FillDirection = direction or Enum.FillDirection.Vertical
        l.Padding = UDim.new(0, padding or 0)
        l.HorizontalAlignment = halign or Enum.HorizontalAlignment.Left
        l.VerticalAlignment = valign or Enum.VerticalAlignment.Top
        l.Parent = parent
        return l
    end)
    return success and result or nil
end

