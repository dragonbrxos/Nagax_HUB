        box.BackgroundColor3 = customConfig.boxBg or C.bg3
        box.BorderSizePixel = 0
        box.Text = ""
        box.PlaceholderText = customConfig.placeholder or "Digite aqui..."
        box.PlaceholderColor3 = C.txt3
        box.TextColor3 = customConfig.boxText or C.txt
        box.TextSize = 11
        box.Font = Enum.Font.Gotham
        box.TextXAlignment = Enum.TextXAlignment.Left
        box.ClearTextOnFocus = (clearOnFocus == true)
        box.ZIndex = 5
        box.Parent = row
        Utils.Corner(box, 6)
        Utils.Stroke(box, 1, customConfig.boxStroke or C.bdr)
        
        box.FocusLost:Connect(function(enterPressed)
            if enterPressed and callback then
                pcall(callback, box.Text)
            end
        end)
        
        return {
            SetText = function(_, t) box.Text = tostring(t or "") end,
            GetText = function() return box.Text end,
            Focus = function() box:CaptureFocus() end
        }
    end
    
    -- Registrar tab
    btn.MouseButton1Click:Connect(function() SelectTab(tabObj) end)
    table.insert(tabs, tabObj)
    
    if #tabs == 1 then
        activeTab = tabObj
        btn.BackgroundColor3 = C.acc
        btn.TextColor3 = C.white
        btn:SetAttribute("active", true)
        scroll.Visible = true
    end
    
    return tabObj
end

