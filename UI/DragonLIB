-- SISTEMA DE SAVE/LOAD CONFIG
-- ═══════════════════════════════════════════════════════════════════════════════
local ConfigSystem = {}
ConfigSystem.FolderName = "DragonLib_Configs"

function ConfigSystem:GetFolder()
    local folder = nil
    
    -- Tentar diferentes locais
    pcall(function()
        folder = game:GetService("CoreGui"):FindFirstChild(ConfigSystem.FolderName)
    end)
    
    if not folder then
        pcall(function()
            folder = Instance.new("Folder")
            folder.Name = ConfigSystem.FolderName
            folder.Parent = game:GetService("CoreGui")
        end)
    end
    
    return folder
end

function DragonLib:SaveConfig(configName, data)
    configName = configName or "Default"
    
    local success = pcall(function()
        local folder = ConfigSystem:GetFolder()
        local configValue = folder:FindFirstChild(configName)
        
        if not configValue then
            configValue = Instance.new("StringValue")
            configValue.Name = configName
            configValue.Parent = folder
        end
        
        configValue.Value = game:GetService("HttpService"):JSONEncode(data)
    end)
    
    if success then
        DebugLog:Log("INFO", "Config salva: " .. configName)
        self:Notify("Config", "Configuração '" .. configName .. "' salva!", 3, "success")
    else
        DebugLog:Log("ERROR", "Falha ao salvar config: " .. configName)
        self:Notify("Erro", "Falha ao salvar config!", 3, "error")
    end
    
    return success
end

function DragonLib:LoadConfig(configName)
    configName = configName or "Default"
    
    local success, data = pcall(function()
        local folder = ConfigSystem:GetFolder()
        local configValue = folder:FindFirstChild(configName)
        
        if configValue then
            return game:GetService("HttpService"):JSONDecode(configValue.Value)
        end
        return nil
    end)
    
    if success and data then
        DebugLog:Log("INFO", "Config carregada: " .. configName)
        return data
    else
        DebugLog:Log("WARN", "Config não encontrada: " .. configName)
        return nil
    end
end

function DragonLib:DeleteConfig(configName)
    local success = pcall(function()
        local folder = ConfigSystem:GetFolder()
        local configValue = folder:FindFirstChild(configName)
        if configValue then
            configValue:Destroy()
        end
    end)
    
    if success then
        DebugLog:Log("INFO", "Config deletada: " .. configName)
    end
    
    return success
end

function DragonLib:GetConfigs()
    local configs = {}
    pcall(function()
        local folder = ConfigSystem:GetFolder()
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("StringValue") then
                table.insert(configs, child.Name)
            end
        end
    end)
    return configs
end

