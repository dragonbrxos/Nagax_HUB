-- SISTEMA DE LOG E DIAGNÓSTICO
-- ═══════════════════════════════════════════════════════════════════════════════
local DebugLog = {
    enabled = true,
    logs = {},
    maxLogs = 100
}

function DebugLog:Log(level, message, data)
    if not self.enabled then return end
    local entry = {
        time = tick(),
        level = level or "INFO",
        message = message,
        data = data
    }
    table.insert(self.logs, 1, entry)
    if #self.logs > self.maxLogs then
        table.remove(self.logs)
    end
    print(string.format("[DragonLib:%s] %s", level, message))
end

function DebugLog:GetLogs()
    return self.logs
end

function DebugLog:Clear()
    self.logs = {}
end

