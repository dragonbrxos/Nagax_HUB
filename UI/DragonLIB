-- SISTEMA DE VERIFICAÇÃO DE INSTÂNCIAS
-- ═══════════════════════════════════════════════════════════════════════════════
local InstanceValidator = {}

function InstanceValidator:IsValid(obj)
    if not obj then return false end
    local success, exists = pcall(function()
        return obj.Parent ~= nil
    end)
    return success and exists
end

function InstanceValidator:WaitForParent(obj, timeout)
    timeout = timeout or 5
    local start = tick()
    while tick() - start < timeout do
        local success, parent = pcall(function()
            return obj.Parent
        end)
        if success and parent then
            return true
        end
        task.wait(0.05)
    end
    return false
end

function InstanceValidator:SafeSetParent(obj, parent)
    local success = pcall(function()
        obj.Parent = parent
    end)
    if not success then
        -- Tentar método alternativo
        success = pcall(function()
            obj.Parent = parent
        end)
    end
    return success
end

