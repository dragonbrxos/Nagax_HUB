-- SISTEMA DE ANIMAÇÕES AVANÇADAS
-- ═══════════════════════════════════════════════════════════════════════════════
local AnimationSystem = {}

function AnimationSystem:FadeIn(obj, duration)
    duration = duration or 0.3
    obj.BackgroundTransparency = 1
    Utils.Tween(obj, {BackgroundTransparency = 0}, duration)
end

function AnimationSystem:FadeOut(obj, duration)
    duration = duration or 0.3
    Utils.Tween(obj, {BackgroundTransparency = 1}, duration)
end

function AnimationSystem:SlideIn(obj, direction, duration)
    direction = direction or "left"
    duration = duration or 0.3
    
    local originalPos = obj.Position
    local startPos
    
    if direction == "left" then
        startPos = UDim2.new(-1, 0, originalPos.Y.Scale, originalPos.Y.Offset)
    elseif direction == "right" then
        startPos = UDim2.new(1, 0, originalPos.Y.Scale, originalPos.Y.Offset)
    elseif direction == "top" then
        startPos = UDim2.new(originalPos.X.Scale, originalPos.X.Offset, -1, 0)
    elseif direction == "bottom" then
        startPos = UDim2.new(originalPos.X.Scale, originalPos.X.Offset, 1, 0)
    end
    
    obj.Position = startPos
    Utils.Tween(obj, {Position = originalPos}, duration)
end

function AnimationSystem:Pulse(obj, scale, duration)
    scale = scale or 1.1
    duration = duration or 0.2
    
    local originalSize = obj.Size
    local expandedSize = UDim2.new(
        originalSize.X.Scale * scale,
        originalSize.X.Offset,
        originalSize.Y.Scale * scale,
        originalSize.Y.Offset
    )
    
    Utils.Tween(obj, {Size = expandedSize}, duration)
    task.wait(duration)
    Utils.Tween(obj, {Size = originalSize}, duration)
end

function AnimationSystem:Shake(obj, intensity, duration)
    intensity = intensity or 5
    duration = duration or 0.3
    
    local originalPos = obj.Position
    local startTime = tick()
    
    while tick() - startTime < duration do
        local offsetX = math.random(-intensity, intensity)
        local offsetY = math.random(-intensity, intensity)
        obj.Position = UDim2.new(
            originalPos.X.Scale,
            originalPos.X.Offset + offsetX,
            originalPos.Y.Scale,
            originalPos.Y.Offset + offsetY
        )
        task.wait(0.02)
    end
    
    obj.Position = originalPos
end

function DragonLib:Animate(obj, animType, ...)
    if AnimationSystem[animType] then
        return AnimationSystem[animType](AnimationSystem, obj, ...)
    end
end

