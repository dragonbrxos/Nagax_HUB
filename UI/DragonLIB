-- Método 9: Criação com Retry Automático
function ButtonLibrary:Method_AutoRetry(parent, config)
    DebugLog:Log("INFO", "Tentando Método 9: AutoRetry")
    
    local maxRetries = 5
    local result = nil
    
    for i = 1, maxRetries do
        local success, res = pcall(function()
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, config.height or 34)
            row.BackgroundColor3 = config.rowColor or C.bg4
            row.BorderSizePixel = 0
            row.Parent = parent
            Utils.Corner(row, 7)
            
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -16, 0, 26)
            b.Position = UDim2.new(0, 8, 0.5, -13)
            b.BackgroundColor3 = config.bgColor or C.acc
            b.Text = config.text or "Botão"
            b.TextColor3 = config.textColor or C.white
            b.TextSize = 11
            b.Font = Enum.Font.GothamBold
            b.AutoButtonColor = false
            b.Parent = row
            Utils.Corner(b, 6)
            
            -- Verificar se foi criado corretamente
            if not b.Parent then
                error("Botão não foi parenteado")
            end
            
            b.MouseButton1Click:Connect(function()
                if config.callback then pcall(config.callback) end
            end)
            
            return {Button = b, Row = row, Method = "AutoRetry"}
        end)
        
        if success then
            result = res
            break
        else
            DebugLog:Log("WARN", string.format("Retry %d falhou, tentando novamente...", i))
            task.wait(0.1 * i) -- Backoff exponencial
        end
    end
    
    if result then
        table.insert(self.SuccessLog, {Method = "AutoRetry", Time = tick()})
    end
    return result
end

