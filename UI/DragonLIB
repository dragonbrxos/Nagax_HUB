function DragonLib:CreateRipple(button, color)
    color = color or C.white
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local ripple = Instance.new("Frame")
            ripple.Size = UDim2.new(0, 0, 0, 0)
            ripple.Position = UDim2.new(0, input.Position.X - button.AbsolutePosition.X, 0, input.Position.Y - button.AbsolutePosition.Y)
            ripple.BackgroundColor3 = color
            ripple.BackgroundTransparency = 0.7
            ripple.BorderSizePixel = 0
            ripple.ZIndex = button.ZIndex + 1
            ripple.Parent = button
            Utils.Corner(ripple, 100)
            
            local targetSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2
            
            Utils.Tween(ripple, {
                Size = UDim2.new(0, targetSize, 0, targetSize),
                Position = UDim2.new(0, input.Position.X - button.AbsolutePosition.X - targetSize/2, 0, input.Position.Y - button.AbsolutePosition.Y - targetSize/2),
                BackgroundTransparency = 1
            }, 0.5)
            
            task.delay(0.5, function()
                ripple:Destroy()
            end)
        end
    end)
end

function DragonLib:TypewriterEffect(label, text, speed)
    speed = speed or 0.05
    label.Text = ""
    
    task.spawn(function()
        for i = 1, #text do
            label.Text = string.sub(text, 1, i)
            task.wait(speed)
        end
    end)
end

function DragonLib:CountUp(label, startVal, endVal, duration, prefix, suffix)
    prefix = prefix or ""
    suffix = suffix or ""
    duration = duration or 1
    
    local steps = 30
    local stepDuration = duration / steps
    local stepValue = (endVal - startVal) / steps
    
    task.spawn(function()
        for i = 0, steps do
            local current = math.floor(startVal + (stepValue * i))
            label.Text = prefix .. tostring(current) .. suffix
            task.wait(stepDuration)
        end
        label.Text = prefix .. tostring(endVal) .. suffix
    end)
end

