local NotificationSystem = {}
NotificationSystem.ActiveNotifications = {}

function DragonLib:Notify(title, message, duration, notifType)
    duration = duration or 3
    notifType = notifType or "info"
    
    local notifColors = {
        info = C.acc,
        success = C.on,
        warning = Color3.fromRGB(255, 170, 0),
        error = C.close
    }
    
    local color = notifColors[notifType] or C.acc
    
    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 280, 0, 70)
    notifFrame.Position = UDim2.new(1, 300, 1, -90 - (#NotificationSystem.ActiveNotifications * 80))
    notifFrame.BackgroundColor3 = C.bg2
    notifFrame.BorderSizePixel = 0
    notifFrame.Parent = sg
    Utils.Corner(notifFrame, 10)
    Utils.Stroke(notifFrame, 1, color)
    
    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 4, 1, 0)
    accentBar.BackgroundColor3 = color
    accentBar.BorderSizePixel = 0
    accentBar.Parent = notifFrame
    Utils.Corner(accentBar, 2)
    
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, -20, 0, 22)
    titleLbl.Position = UDim2.new(0, 14, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title or "Notificação"
    titleLbl.TextColor3 = color
    titleLbl.TextSize = 13
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = notifFrame
    
    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size = UDim2.new(1, -20, 0, 30)
    msgLbl.Position = UDim2.new(0, 14, 0, 32)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text = message or ""
    msgLbl.TextColor3 = C.txt2
    msgLbl.TextSize = 11
    msgLbl.Font = Enum.Font.Gotham
    msgLbl.TextXAlignment = Enum.TextXAlignment.Left
    msgLbl.TextWrapped = true
    msgLbl.Parent = notifFrame
    
    table.insert(NotificationSystem.ActiveNotifications, notifFrame)
    
    -- Animação de entrada
    Utils.Tween(notifFrame, {Position = UDim2.new(1, -300, 1, -90 - ((#NotificationSystem.ActiveNotifications - 1) * 80))}, 0.3)
    
    -- Auto remover
    task.delay(duration, function()
        Utils.Tween(notifFrame, {Position = UDim2.new(1, 300, notifFrame.Position.Y.Scale, notifFrame.Position.Y.Offset)}, 0.3)
        task.wait(0.3)
        notifFrame:Destroy()
        
        -- Remover da lista e reorganizar
        for i, n in ipairs(NotificationSystem.ActiveNotifications) do
            if n == notifFrame then
                table.remove(NotificationSystem.ActiveNotifications, i)
                break
            end
        end
        
        -- Reorganizar notificações restantes
        for i, n in ipairs(NotificationSystem.ActiveNotifications) do
            Utils.Tween(n, {Position = UDim2.new(1, -300, 1, -90 - ((i - 1) * 80))}, 0.2)
        end
    end)
end

