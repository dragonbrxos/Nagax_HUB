-- SISTEMA DE FALLBACK AUTOMÁTICO
-- ═══════════════════════════════════════════════════════════════════════════════
function ButtonLibrary:CreateButtonWithFallback(parent, config)
    DebugLog:Log("INFO", "Iniciando criação de botão com fallback automático")
    
    config = config or {}
    local methods = {
        self.Method_Standard,
        self.Method_Delayed,
        self.Method_Deferred,
        self.Method_Spawn,
        self.Method_Stepped,
        self.Method_CanvasGroup,
        self.Method_FrameContainer,
        self.Method_BindableEvent,
        self.Method_AutoRetry,
        self.Method_ParentCheck,
        self.Method_TableProps,
        self.Method_ImageButton,
        self.Method_Coroutine,
        self.Method_Heartbeat,
        self.Method_UltraSafe
    }
    
    for i, method in ipairs(methods) do
        local result = method(self, parent, config)
        if result then
            DebugLog:Log("SUCCESS", string.format("Método %d (%s) funcionou!", i, result.Method))
            
            -- Atualizar status
            pcall(function()
                stMethodLbl.Text = "Método: " .. result.Method
            end)
            
            return result
        end
        DebugLog:Log("WARN", string.format("Método %d falhou, tentando próximo...", i))
    end
    
    DebugLog:Log("ERROR", "Todos os métodos falharam!")
    return nil
end

