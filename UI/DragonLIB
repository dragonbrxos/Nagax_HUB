-- SISTEMA DE TABS
-- ═══════════════════════════════════════════════════════════════════════════════
local tabs = {}
local activeTab = nil

local function SelectTab(t)
    if activeTab == t then return end
    if activeTab then
        Utils.Tween(activeTab._btn, {BackgroundColor3 = activeTab._btnColor or C.bg3})
        activeTab._btn.TextColor3 = activeTab._txtColor or C.txt2
        activeTab._btn:SetAttribute("active", false)
        activeTab._scroll.Visible = false
    end
    activeTab = t
    Utils.Tween(t._btn, {BackgroundColor3 = t._activeColor or C.acc})
    t._btn.TextColor3 = C.white
    t._btn:SetAttribute("active", true)
    t._scroll.Visible = true
end

