-- SISTEMA DE PROGRESSO
-- ═══════════════════════════════════════════════════════════════════════════════
function DragonLib:CreateProgressBar(parent, config)
    config = config or {}
    
    local container = Instance.new("Frame")
    container.Size = config.size or UDim2.new(1, 0, 0, 20)
    container.BackgroundColor3 = config.bgColor or C.bg3
    container.BorderSizePixel = 0
    container.Parent = parent
    Utils.Corner(container, 10)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = config.fillColor or C.acc
    fill.BorderSizePixel = 0
    fill.Parent = container
    Utils.Corner(fill, 10)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = config.text or "0%"
    label.TextColor3 = config.textColor or C.txt
    label.TextSize = 10
    label.Font = Enum.Font.GothamBold
    label.Parent = container
    
    return {
        Container = container,
        Fill = fill,
        Label = label,
        SetProgress = function(_, percent)
            percent = math.clamp(percent, 0, 100)
            fill.Size = UDim2.new(percent / 100, 0, 1, 0)
            label.Text = string.format("%d%%", percent)
        end,
        TweenProgress = function(_, percent, duration)
            percent = math.clamp(percent, 0, 100)
            duration = duration or 0.5
            Utils.Tween(fill, {Size = UDim2.new(percent / 100, 0, 1, 0)}, duration)
            
            -- Atualizar texto
            task.spawn(function()
                local start = tick()
                local startPercent = fill.Size.X.Scale * 100
                while tick() - start < duration do
                    local elapsed = tick() - start
                    local current = startPercent + (percent - startPercent) * (elapsed / duration)
                    label.Text = string.format("%d%%", math.floor(current))
                    task.wait(0.03)
                end
                label.Text = string.format("%d%%", percent)
            end)
        end
    }
end

