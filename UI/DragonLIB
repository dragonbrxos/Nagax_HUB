            stroke = C.seaBlue
        })
    end
    
    -- Registrar
    btn.MouseButton1Click:Connect(function() SelectTab(tabObj) end)
    table.insert(tabs, tabObj)
    
    if #tabs == 1 then
        activeTab = tabObj
        btn.BackgroundColor3 = C.seaBlue
        btn.TextColor3 = C.white
        btn:SetAttribute("active", true)
        scroll.Visible = true
    end
    
    DebugLog:Log("SUCCESS", "Sea Event Tab criada com sucesso")
    return tabObj
end

