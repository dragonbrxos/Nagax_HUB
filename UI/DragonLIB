        local hdrDD = Instance.new("TextButton")
        hdrDD.Size = UDim2.new(1, 0, 0, 36)
        hdrDD.BackgroundTransparency = 1
        hdrDD.Text = "▼ " .. (labelText or "") .. ": " .. selected
        hdrDD.TextColor3 = customConfig.textColor or C.txt
        hdrDD.TextSize = 11
        hdrDD.Font = Enum.Font.Gotham
        hdrDD.TextXAlignment = Enum.TextXAlignment.Left
        hdrDD.AutoButtonColor = false
        hdrDD.ZIndex = 11
        hdrDD.Parent = container
        
        local hdrPad = Instance.new("UIPadding")
        hdrPad.PaddingLeft = UDim.new(0, 12)
        hdrPad.Parent = hdrDD
        
        local optFrame = Instance.new("Frame")
        optFrame.Size = UDim2.new(1, 0, 0, 0)
        optFrame.Position = UDim2.new(0, 0, 0, 36)
        optFrame.BackgroundColor3 = C.bg2
        optFrame.BorderSizePixel = 0
        optFrame.ClipsDescendants = true
        optFrame.ZIndex = 20
        optFrame.Visible = false
        optFrame.Parent = container
        Utils.Corner(optFrame, 8)
        Utils.Stroke(optFrame, 1, customConfig.stroke or C.bdr)
        
        Utils.Padding(optFrame, 4, 4, 4, 4)
        local optList = Utils.ListLayout(optFrame, Enum.FillDirection.Vertical, 3)
        
        local function buildOpts(opts)
            for _, ch in ipairs(optFrame:GetChildren()) do
                if ch:IsA("TextButton") then ch:Destroy() end
            end
            for _, opt in ipairs(opts) do
                local ob = Instance.new("TextButton")
                ob.Size = UDim2.new(1, 0, 0, 28)
                ob.BackgroundColor3 = C.bg3
                ob.BorderSizePixel = 0
                ob.Text = tostring(opt)
                ob.TextColor3 = C.txt
                ob.TextSize = 11
                ob.Font = Enum.Font.Gotham
                ob.TextXAlignment = Enum.TextXAlignment.Left
                ob.AutoButtonColor = false
                ob.ZIndex = 21
                ob.Parent = optFrame
                Utils.Corner(ob, 6)
                
                local oPad = Instance.new("UIPadding")
                oPad.PaddingLeft = UDim.new(0, 10)
                oPad.Parent = ob
                
                ob.MouseEnter:Connect(function() Utils.Tween(ob, {BackgroundColor3 = C.bg4}) end)
                ob.MouseLeave:Connect(function() Utils.Tween(ob, {BackgroundColor3 = C.bg3}) end)
                ob.MouseButton1Click:Connect(function()
                    selected = tostring(opt)
                    hdrDD.Text = "▼ " .. (labelText or "") .. ": " .. selected
                    open = false
                    optFrame.Visible = false
                    container.Size = UDim2.new(1, 0, 0, 36)
                    if callback then pcall(callback, selected) end
                end)
            end
            optFrame.Size = UDim2.new(1, 0, 0, #opts * 31 + 8)
        end
        
        buildOpts(options)
        
        hdrDD.MouseButton1Click:Connect(function()
            open = not open
            optFrame.Visible = open
            container.Size = open and UDim2.new(1, 0, 0, 36 + #options * 31 + 8) or UDim2.new(1, 0, 0, 36)
        end)
        
        if callback then pcall(callback, selected) end
        
        return {
            Refresh = function(_, newOpts)
                options = newOpts or {}
                selected = tostring(options[1] or "")
                hdrDD.Text = "▼ " .. (labelText or "") .. ": " .. selected
                buildOpts(options)
                if callback then pcall(callback, selected) end
            end,
            Add = function(_, opt)
                table.insert(options, opt)
                buildOpts(options)
            end,
            Clear = function(_)
                options = {}
                selected = ""
                hdrDD.Text = "▼ " .. (labelText or "") .. ": "
                for _, ch in ipairs(optFrame:GetChildren()) do
                    if ch:IsA("TextButton") then ch:Destroy() end
                end
                container.Size = UDim2.new(1, 0, 0, 36)
                optFrame.Visible = false
                open = false
            end
        }
    end
    
    -- TEXTBOX
    function tabObj:TextBox(labelText, callback, clearOnFocus, customConfig)
        customConfig = customConfig or {}
        local row = self:MakeRow(56)
        
        local lbl = Instance.new("TextLabel")
