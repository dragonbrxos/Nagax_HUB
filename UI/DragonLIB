        track.BorderSizePixel  = 0
        track.Parent           = row
        corner(track, 3)

        local pct0 = (value - minV) / range
        local fill = Instance.new("Frame")
        fill.Size             = UDim2.new(pct0,0,1,0)
        fill.BackgroundColor3 = C.raceGold
        fill.BorderSizePixel  = 0
        fill.Parent           = track
        corner(fill, 3)

        local knob = Instance.new("Frame")
        knob.Size             = UDim2.new(0,18,0,18)
        knob.AnchorPoint      = Vector2.new(0.5,0.5)
        knob.Position         = UDim2.new(pct0,0,0.5,0)
        knob.BackgroundColor3 = C.white
        knob.BorderSizePixel  = 0
        knob.ZIndex           = 3
        knob.Parent           = track
        corner(knob, 9)

        local draggingSlider = false

        local hit = Instance.new("TextButton")
        hit.Size                   = UDim2.new(1,0,4,8)
        hit.Position               = UDim2.new(0,0,0,-10)
        hit.BackgroundTransparency = 1
        hit.Text                   = ""
        hit.ZIndex                 = 5
        hit.Parent                 = track

        local function updateSlider(mx)
            local ax  = track.AbsolutePosition.X
            local aw  = track.AbsoluteSize.X
            local pct = math.clamp((mx - ax) / math.max(aw,1), 0, 1)
            value     = math.floor(minV + pct * range + 0.5)
            local v2  = (value - minV) / range
            fill.Size     = UDim2.new(v2, 0, 1, 0)
            knob.Position = UDim2.new(v2, 0, 0.5, 0)
            lbl.Text      = (labelText or "") .. ":  " .. tostring(value)
            if callback then pcall(callback, value) end
        end

        hit.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = true
                updateSlider(inp.Position.X)
            end
        end)
        hit.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = false
            end
        end)

        uis.InputChanged:Connect(function(inp)
            if not draggingSlider then return end
            if inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch then
                updateSlider(inp.Position.X)
            end
        end)
        uis.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = false
            end
        end)

        if callback then pcall(callback, value) end
    end

    -- Label especial para Race V4
    function tabObj:RaceLabel(text)
        local row = makeRow(20, true)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1,-10,1,0)
        lbl.Position              = UDim2.new(0,6,0,0)
        lbl.BackgroundTransparency= 1
        lbl.Text                  = text or ""
        lbl.TextColor3            = C.raceGold
        lbl.TextSize              = 10
        lbl.Font                  = Enum.Font.Gotham
        lbl.TextXAlignment        = Enum.TextXAlignment.Left
        lbl.TextWrapped           = true
        lbl.Parent                = row

        local obj = {}
        function obj:Set(t) lbl.Text = tostring(t or "") end
        return setmetatable(obj, {
            __newindex = function(_, k, v)
                if k == "Text" then lbl.Text = tostring(v or "") end
            end,
            __index = function(_, k)
                if k == "Text" then return lbl.Text end
            end,
        })
    end

    -- Registrar tab
    btn.MouseButton1Click:Connect(function() selectTab(tabObj) end)
    table.insert(tabs, tabObj)
    
    -- Auto-selecionar se for a primeira tab
    if #tabs == 1 then
        activeTab                = tabObj
        btn.BackgroundColor3     = C.raceGold
        btn.TextColor3           = C.bg
        btn:SetAttribute("active", true)
        scroll.Visible           = true
    end

    return tabObj
end

