-- ═══════════════════════════════════════════════════════════════════════════════

function DragonLib:Lerp(a, b, t)
    return a + (b - a) * t
end

function DragonLib:Map(value, inMin, inMax, outMin, outMax)
    return (value - inMin) * (outMax - outMin) / (inMax - inMin) + outMin
end

function DragonLib:Clamp(value, min, max)
    return math.max(min, math.min(max, value))
end

function DragonLib:Round(value, decimals)
    decimals = decimals or 0
    local mult = 10 ^ decimals
    return math.floor(value * mult + 0.5) / mult
end

function DragonLib:FormatNumber(num)
    if num >= 1000000000 then
        return string.format("%.1fB", num / 1000000000)
    elseif num >= 1000000 then
        return string.format("%.1fM", num / 1000000)
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000)
    end
    return tostring(num)
end

function DragonLib:FormatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = seconds % 60
    
    if hours > 0 then
        return string.format("%02d:%02d:%02d", hours, minutes, secs)
    else
        return string.format("%02d:%02d", minutes, secs)
    end
end

function DragonLib:RandomString(length)
    length = length or 10
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local result = ""
    for i = 1, length do
        local rand = math.random(1, #chars)
        result = result .. string.sub(chars, rand, rand)
    end
    return result
end

function DragonLib:DeepCopy(orig)
    local copy
    if type(orig) == "table" then
        copy = {}
        for orig_key, orig_value in next, orig, nil do
            copy[DragonLib:DeepCopy(orig_key)] = DragonLib:DeepCopy(orig_value)
        end
        setmetatable(copy, DragonLib:DeepCopy(getmetatable(orig)))
    else
        copy = orig
    end
    return copy
end

function DragonLib:MergeTables(t1, t2)
    local result = DragonLib:DeepCopy(t1)
    for k, v in pairs(t2) do
        result[k] = v
    end
    return result
end

