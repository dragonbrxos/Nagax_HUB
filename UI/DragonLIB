-- FUNCOES AUXILIARES PARA CONTROLE EXTERNO
-- ═══════════════════════════════════════════════════════════════════════════════

-- Funcao para verificar se uma tab existe
function NagaxLib:TabExists(name)
    for _, t in ipairs(tabs) do
        if t._btn.Text == name then
            return true
        end
    end
    return false
end

-- Funcao para obter uma tab pelo nome
function NagaxLib:GetTab(name)
    for _, t in ipairs(tabs) do
        if t._btn.Text == name then
            return t
        end
    end
    return nil
end

-- Funcao para destruir uma tab
function NagaxLib:DestroyTab(name)
    for i, t in ipairs(tabs) do
        if t._btn.Text == name then
            t._btn:Destroy()
            t._scroll:Destroy()
            table.remove(tabs, i)
            return true
        end
    end
    return false
end

-- Funcao para recriar tabs especiais (util para reload)
function NagaxLib:RecreateSeaEventTab()
    self:DestroyTab("Mar Event")
    return self:CreateSeaEventTab()
end

function NagaxLib:RecreateRaceV4Tab()
    self:DestroyTab("Race V4")
    return self:CreateRaceV4Tab()
end

return NagaxLib
