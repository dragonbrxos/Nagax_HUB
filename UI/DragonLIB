-- ═══════════════════════════════════════════════════════════════════════════════
local KeybindSystem = {}
KeybindSystem.Keybinds = {}

function DragonLib:AddKeybind(key, callback, name)
    name = name or "Keybind_" .. tostring(key)
    
    local connection = uis.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == key then
            local ok, err = pcall(callback)
            if not ok then
                DebugLog:Log("ERROR", "Keybind " .. name .. " erro: " .. tostring(err))
            end
        end
    end)
    
    KeybindSystem.Keybinds[name] = {
        Key = key,
        Connection = connection,
        Callback = callback
    }
    
    DebugLog:Log("INFO", "Keybind adicionado: " .. name .. " (" .. tostring(key) .. ")")
    return connection
end

function DragonLib:RemoveKeybind(name)
    if KeybindSystem.Keybinds[name] then
        pcall(function()
            KeybindSystem.Keybinds[name].Connection:Disconnect()
        end)
        KeybindSystem.Keybinds[name] = nil
        DebugLog:Log("INFO", "Keybind removido: " .. name)
        return true
    end
    return false
end

function DragonLib:GetKeybinds()
    return KeybindSystem.Keybinds
end

