-- Método 15: Criação Ultra-Segura (Fallback final)
function ButtonLibrary:Method_UltraSafe(parent, config)
    DebugLog:Log("INFO", "Tentando Método 15: UltraSafe (Fallback)")
    
    local result = nil
    
    -- Tentar múltiplas abordagens em sequência
    local attempts = {
        function()
            return ButtonLibrary:Method_Standard(parent, config)
        end,
        function()
            task.wait(0.1)
            return ButtonLibrary:Method_Delayed(parent, config)
        end,
        function()
            return ButtonLibrary:Method_AutoRetry(parent, config)
        end
    }
    
    for i, attempt in ipairs(attempts) do
        local success, res = pcall(attempt)
        if success and res then
            result = res
            result.Method = "UltraSafe_" .. i
            break
        end
    end
    
    if result then
        table.insert(self.SuccessLog, {Method = "UltraSafe", Time = tick()})
    end
    return result
end

