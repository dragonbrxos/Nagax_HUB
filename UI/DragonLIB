-- Tentar parentear de múltiplas formas
local function SafeParentGui(gui)
    local methods = {
        function() gui.Parent = playerGui end,
        function() gui.Parent = coreGui end,
        function() gui.Parent = lp:FindFirstChildOfClass("PlayerGui") end,
        function() 
            local pg = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui", 5)
            gui.Parent = pg
        end
    }
    
    for i, method in ipairs(methods) do
        local success = pcall(method)
        if success and gui.Parent then
            DebugLog:Log("INFO", string.format("GUI parenteada com método %d", i))
            return true
        end
    end
    return false
end

