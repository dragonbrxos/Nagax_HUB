-- SISTEMA DE COLOR PICKER SIMPLES
-- ═══════════════════════════════════════════════════════════════════════════════
function DragonLib:ColorPicker(parent, defaultColor, callback)
    defaultColor = defaultColor or C.acc
    
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, 200, 0, 180)
    container.BackgroundColor3 = C.bg2
    container.BorderSizePixel = 0
    container.Parent = parent
    Utils.Corner(container, 10)
    Utils.Stroke(container, 1, C.bdr)
    
    local preview = Instance.new("Frame")
    preview.Size = UDim2.new(0, 50, 0, 50)
    preview.Position = UDim2.new(1, -60, 0, 10)
    preview.BackgroundColor3 = defaultColor
    preview.BorderSizePixel = 0
    preview.Parent = container
    Utils.Corner(preview, 8)
    
    local currentColor = defaultColor
    local sliders = {}
    
    local colors = {
        {name = "R", max = 255, default = defaultColor.R * 255},
        {name = "G", max = 255, default = defaultColor.G * 255},
        {name = "B", max = 255, default = defaultColor.B * 255}
    }
    
    for i, colorData in ipairs(colors) do
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0, 20, 0, 20)
        lbl.Position = UDim2.new(0, 10, 0, 15 + (i - 1) * 45)
        lbl.BackgroundTransparency = 1
        lbl.Text = colorData.name
        lbl.TextColor3 = C.txt
        lbl.TextSize = 12
        lbl.Font = Enum.Font.GothamBold
        lbl.Parent = container
        
        local track = Instance.new("Frame")
        track.Size = UDim2.new(0, 100, 0, 8)
        track.Position = UDim2.new(0, 35, 0, 21 + (i - 1) * 45)
        track.BackgroundColor3 = C.bg3
        track.BorderSizePixel = 0
        track.Parent = container
        Utils.Corner(track, 4)
        
        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(colorData.default / colorData.max, 0, 1, 0)
        fill.BackgroundColor3 = currentColor
        fill.BorderSizePixel = 0
        fill.Parent = track
        Utils.Corner(fill, 4)
        
        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 14, 0, 14)
        knob.AnchorPoint = Vector2.new(0.5, 0.5)
        knob.Position = UDim2.new(colorData.default / colorData.max, 0, 0.5, 0)
        knob.BackgroundColor3 = C.white
        knob.BorderSizePixel = 0
        knob.ZIndex = 3
        knob.Parent = track
        Utils.Corner(knob, 7)
        
        local valueLbl = Instance.new("TextLabel")
        valueLbl.Size = UDim2.new(0, 35, 0, 20)
        valueLbl.Position = UDim2.new(0, 140, 0, 15 + (i - 1) * 45)
        valueLbl.BackgroundTransparency = 1
        valueLbl.Text = tostring(math.floor(colorData.default))
        valueLbl.TextColor3 = C.txt2
        valueLbl.TextSize = 10
        valueLbl.Font = Enum.Font.Gotham
        valueLbl.Parent = container
        
        table.insert(sliders, {
            track = track,
            fill = fill,
            knob = knob,
            valueLbl = valueLbl,
            index = i
        })
        
        -- Interação
        local dragging = false
        
        track.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                local ax = track.AbsolutePosition.X
                local aw = track.AbsoluteSize.X
                local pct = math.clamp((inp.Position.X - ax) / aw, 0, 1)
                local value = pct * colorData.max
                
                fill.Size = UDim2.new(pct, 0, 1, 0)
                knob.Position = UDim2.new(pct, 0, 0.5, 0)
                valueLbl.Text = tostring(math.floor(value))
                
                -- Atualizar cor
                local r, g, b = currentColor.R * 255, currentColor.G * 255, currentColor.B * 255
                if i == 1 then r = value
                elseif i == 2 then g = value
                else b = value end
                
                currentColor = Color3.fromRGB(r, g, b)
                preview.BackgroundColor3 = currentColor
                
                if callback then pcall(callback, currentColor) end
            end
        end)
        
        uis.InputChanged:Connect(function(inp)
            if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local ax = track.AbsolutePosition.X
                local aw = track.AbsoluteSize.X
                local pct = math.clamp((inp.Position.X - ax) / aw, 0, 1)
                local value = pct * colorData.max
                
                fill.Size = UDim2.new(pct, 0, 1, 0)
                knob.Position = UDim2.new(pct, 0, 0.5, 0)
                valueLbl.Text = tostring(math.floor(value))
                
                local r, g, b = currentColor.R * 255, currentColor.G * 255, currentColor.B * 255
                if i == 1 then r = value
                elseif i == 2 then g = value
                else b = value end
                
                currentColor = Color3.fromRGB(r, g, b)
                preview.BackgroundColor3 = currentColor
                
                if callback then pcall(callback, currentColor) end
            end
        end)
        
        uis.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end
    
    return {
        Container = container,
        GetColor = function() return currentColor end,
        SetColor = function(_, color)
            currentColor = color
            preview.BackgroundColor3 = color
            -- Atualizar sliders
            sliders[1].fill.Size = UDim2.new(color.R, 0, 1, 0)
            sliders[1].knob.Position = UDim2.new(color.R, 0, 0.5, 0)
            sliders[1].valueLbl.Text = tostring(math.floor(color.R * 255))
            sliders[2].fill.Size = UDim2.new(color.G, 0, 1, 0)
            sliders[2].knob.Position = UDim2.new(color.G, 0, 0.5, 0)
            sliders[2].valueLbl.Text = tostring(math.floor(color.G * 255))
            sliders[3].fill.Size = UDim2.new(color.B, 0, 1, 0)
            sliders[3].knob.Position = UDim2.new(color.B, 0, 0.5, 0)
            sliders[3].valueLbl.Text = tostring(math.floor(color.B * 255))
        end
    }
end

