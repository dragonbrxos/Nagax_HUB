-- FUNÇÃO TAB BASE EXPANDIDA
-- ═══════════════════════════════════════════════════════════════════════════════
function DragonLib:Tab(name, customColors)
    customColors = customColors or {}
    
    local btn = Instance.new("TextButton")
    btn.Name = "Tab_" .. name
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.BackgroundColor3 = customColors.bg or C.bg3
    btn.BorderSizePixel = 0
    btn.Text = name
    btn.TextColor3 = customColors.txt or C.txt2
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false
    btn.LayoutOrder = #tabs + 1
    btn.Parent = sidebar
    Utils.Corner(btn, 8)
    
    local btnPad = Instance.new("UIPadding")
    btnPad.PaddingLeft = UDim.new(0, 12)
    btnPad.Parent = btn
    
    btn.MouseEnter:Connect(function()
        if not (activeTab and activeTab._btn == btn) then
            Utils.Tween(btn, {BackgroundColor3 = customColors.hover or C.bg4})
        end
    end)
    btn.MouseLeave:Connect(function()
        if not (activeTab and activeTab._btn == btn) then
            Utils.Tween(btn, {BackgroundColor3 = customColors.bg or C.bg3})
        end
    end)
    
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name = "Scroll_" .. name
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = customColors.scrollbar or C.acc3
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.ElasticBehavior = Enum.ElasticBehavior.Never
    scroll.Visible = false
    scroll.Parent = mainPanel
    
    Utils.Padding(scroll, 10, 10, 10, 10)
    Utils.ListLayout(scroll, Enum.FillDirection.Vertical, 6, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Top)
    
    local tabObj = {
        _btn = btn,
        _scroll = scroll,
        _order = 0,
        _btnColor = customColors.bg or C.bg3,
        _txtColor = customColors.txt or C.txt2,
        _activeColor = customColors.active or C.acc,
        _type = "Standard"
    }
    
    function tabObj:NextOrder()
        self._order = self._order + 1
        return self._order
    end
    
    function tabObj:MakeRow(h, transparent, customColor)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, h or 36)
        f.BackgroundColor3 = customColor or C.bg4
        f.BackgroundTransparency = transparent and 1 or 0
        f.BorderSizePixel = 0
        f.LayoutOrder = self:NextOrder()
        f.ClipsDescendants = false
        f.Parent = scroll
        Utils.Corner(f, 8)
        if not transparent then
            Utils.Stroke(f, 1, C.bdr)
        end
        return f
    end
    
    -- SEPARATOR
    function tabObj:Separator(text)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, 28)
        f.BackgroundTransparency = 1
        f.BorderSizePixel = 0
        f.LayoutOrder = self:NextOrder()
        f.Parent = scroll
        
        local lineL = Instance.new("Frame")
        lineL.Size = UDim2.new(0.25, -6, 0, 1)
        lineL.Position = UDim2.new(0, 0, 0.5, 0)
        lineL.BackgroundColor3 = C.acc3
        lineL.BorderSizePixel = 0
        lineL.Parent = f
        
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.5, 0, 1, 0)
