local ButtonLibrary = {}
ButtonLibrary.SuccessLog = {}

-- Método 1: Criação Padrão (Original)
function ButtonLibrary:Method_Standard(parent, config)
    DebugLog:Log("INFO", "Tentando Método 1: Standard")
    
    local success, result = pcall(function()
        local row = config.row or Instance.new("Frame")
        if not config.row then
            row.Size = UDim2.new(1, 0, 0, config.height or 34)
            row.BackgroundColor3 = config.rowColor or C.bg4
            row.BorderSizePixel = 0
            row.Parent = parent
            Utils.Corner(row, 7)
            if not config.noStroke then
                Utils.Stroke(row, 1, config.strokeColor or C.bdr)
            end
        end
        
        local b = Instance.new("TextButton")
        b.Name = config.name or "Button_" .. tostring(tick())
        b.Size = config.size or UDim2.new(1, -16, 0, 26)
        b.Position = config.position or UDim2.new(0, 8, 0.5, -13)
        b.BackgroundColor3 = config.bgColor or C.acc
        b.BorderSizePixel = 0
        b.Text = config.text or "Botão"
        b.TextColor3 = config.textColor or C.white
        b.TextSize = config.textSize or 11
        b.Font = config.font or Enum.Font.GothamBold
        b.AutoButtonColor = false
        b.ZIndex = 10
        b.Parent = row
        Utils.Corner(b, 6)
        
        if config.stroke then
            Utils.Stroke(b, 1, config.strokeColor or C.acc3)
        end
        
        -- Eventos
        b.MouseEnter:Connect(function() 
            Utils.Tween(b, {BackgroundColor3 = config.hoverColor or C.acc2}) 
        end)
        b.MouseLeave:Connect(function() 
            Utils.Tween(b, {BackgroundColor3 = config.bgColor or C.acc}) 
        end)
        b.MouseButton1Down:Connect(function() 
            Utils.Tween(b, {BackgroundColor3 = config.clickColor or C.acc3}, 0.05) 
        end)
        b.MouseButton1Up:Connect(function() 
            Utils.Tween(b, {BackgroundColor3 = config.bgColor or C.acc}, 0.05) 
        end)
        b.MouseButton1Click:Connect(function()
            if config.callback then
                local ok, err = pcall(config.callback)
                if not ok then
                    DebugLog:Log("ERROR", "Callback erro: " .. tostring(err))
                end
            end
        end)
        
        return {Button = b, Row = row, Method = "Standard"}
    end)
    
    if success then
        table.insert(self.SuccessLog, {Method = "Standard", Time = tick()})
        return result
    end
    return nil
end

-- Método 2: Criação com Delay
function ButtonLibrary:Method_Delayed(parent, config)
    DebugLog:Log("INFO", "Tentando Método 2: Delayed")
    
    local result = nil
    local completed = false
    
    task.delay(0.1, function()
        local success, res = pcall(function()
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, config.height or 34)
            row.BackgroundColor3 = config.rowColor or C.bg4
            row.BorderSizePixel = 0
            row.Parent = parent
            Utils.Corner(row, 7)
            
            local b = Instance.new("TextButton")
            b.Name = config.name or "BtnDelayed_" .. tostring(tick())
            b.Size = UDim2.new(1, -16, 0, 26)
            b.Position = UDim2.new(0, 8, 0.5, -13)
            b.BackgroundColor3 = config.bgColor or C.acc
            b.Text = config.text or "Botão"
            b.TextColor3 = config.textColor or C.white
            b.TextSize = 11
            b.Font = Enum.Font.GothamBold
            b.AutoButtonColor = false
            b.Parent = row
            Utils.Corner(b, 6)
            
            b.MouseButton1Click:Connect(function()
                if config.callback then pcall(config.callback) end
            end)
            
            return {Button = b, Row = row, Method = "Delayed"}
        end)
        
        if success then
            result = res
            completed = true
        end
    end)
    
    local start = tick()
    while not completed and tick() - start < 2 do
        task.wait(0.05)
    end
    
    if result then
        table.insert(self.SuccessLog, {Method = "Delayed", Time = tick()})
    end
    return result
end

-- Método 3: Criação com Defer
function ButtonLibrary:Method_Deferred(parent, config)
