-- SISTEMA DE TOOLTIPS
-- ═══════════════════════════════════════════════════════════════════════════════
local TooltipSystem = {}
TooltipSystem.CurrentTooltip = nil

function DragonLib:AddTooltip(element, text, delay)
    delay = delay or 0.5
    
    local tooltipFrame = nil
    local showConnection = nil
    local hideConnection = nil
    
    element.MouseEnter:Connect(function()
        task.delay(delay, function()
            if not element.Parent then return end
            
            -- Remover tooltip anterior
            if TooltipSystem.CurrentTooltip then
                TooltipSystem.CurrentTooltip:Destroy()
            end
            
            tooltipFrame = Instance.new("Frame")
            tooltipFrame.Size = UDim2.new(0, 200, 0, 0)
            tooltipFrame.AutomaticSize = Enum.AutomaticSize.Y
            tooltipFrame.BackgroundColor3 = C.bg2
            tooltipFrame.BorderSizePixel = 0
            tooltipFrame.ZIndex = 100
            tooltipFrame.Parent = sg
            Utils.Corner(tooltipFrame, 6)
            Utils.Stroke(tooltipFrame, 1, C.bdr)
            
            local tooltipText = Instance.new("TextLabel")
            tooltipText.Size = UDim2.new(1, -16, 0, 0)
            tooltipText.AutomaticSize = Enum.AutomaticSize.Y
            tooltipText.Position = UDim2.new(0, 8, 0, 8)
            tooltipText.BackgroundTransparency = 1
            tooltipText.Text = text or ""
            tooltipText.TextColor3 = C.txt2
            tooltipText.TextSize = 10
            tooltipText.Font = Enum.Font.Gotham
            tooltipText.TextWrapped = true
            tooltipText.ZIndex = 101
            tooltipText.Parent = tooltipFrame
            
            local tooltipPad = Instance.new("UIPadding")
            tooltipPad.PaddingBottom = UDim.new(0, 8)
            tooltipPad.Parent = tooltipFrame
            
            -- Posicionar
            local absPos = element.AbsolutePosition
            local absSize = element.AbsoluteSize
            tooltipFrame.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 5)
            
            -- Ajustar se sair da tela
            local screenSize = workspace.CurrentCamera.ViewportSize
            if tooltipFrame.AbsolutePosition.X + tooltipFrame.AbsoluteSize.X > screenSize.X then
                tooltipFrame.Position = UDim2.new(0, screenSize.X - tooltipFrame.AbsoluteSize.X - 10, 0, tooltipFrame.Position.Y.Offset)
            end
            
            TooltipSystem.CurrentTooltip = tooltipFrame
            
            -- Animação
            tooltipFrame.BackgroundTransparency = 1
            tooltipText.TextTransparency = 1
            Utils.Tween(tooltipFrame, {BackgroundTransparency = 0}, 0.2)
            Utils.Tween(tooltipText, {TextTransparency = 0}, 0.2)
        end)
    end)
    
    element.MouseLeave:Connect(function()
        if tooltipFrame then
            Utils.Tween(tooltipFrame, {BackgroundTransparency = 1}, 0.2)
            for _, child in ipairs(tooltipFrame:GetChildren()) do
                if child:IsA("TextLabel") then
                    Utils.Tween(child, {TextTransparency = 1}, 0.2)
                end
            end
            task.delay(0.2, function()
                if tooltipFrame then
                    tooltipFrame:Destroy()
                end
                if TooltipSystem.CurrentTooltip == tooltipFrame then
                    TooltipSystem.CurrentTooltip = nil
                end
            end)
        end
    end)
end

