-- Método 16: Criação com SafeCall
function ButtonLibrary:Method_SafeCall(parent, config)
    DebugLog:Log("INFO", "Tentando Método 16: SafeCall")
    
    local result = nil
    local attempts = 0
    local maxAttempts = 10
    
    while attempts < maxAttempts and not result do
        attempts = attempts + 1
        
        local success, res = pcall(function()
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, config.height or 34)
            row.BackgroundColor3 = config.rowColor or C.bg4
            row.BorderSizePixel = 0
            
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -16, 0, 26)
            b.Position = UDim2.new(0, 8, 0.5, -13)
            b.BackgroundColor3 = config.bgColor or C.acc
            b.Text = config.text or "Botão"
            b.TextColor3 = config.textColor or C.white
            b.TextSize = 11
            b.Font = Enum.Font.GothamBold
            b.AutoButtonColor = false
            
            -- Parentear com verificação
            b.Parent = row
            if not b.Parent then error("Falha ao parentear botão") end
            
            row.Parent = parent
            if not row.Parent then error("Falha ao parentear row") end
            
            Utils.Corner(row, 7)
            Utils.Corner(b, 6)
            
            b.MouseButton1Click:Connect(function()
                if config.callback then pcall(config.callback) end
            end)
            
            return {Button = b, Row = row, Method = "SafeCall"}
        end)
        
        if success then
            result = res
        else
            task.wait(0.05 * attempts)
        end
    end
    
    if result then
        table.insert(self.SuccessLog, {Method = "SafeCall", Time = tick()})
    end
    return result
end

