    -- Borda decorativa da Sidebar (Corrigido - Problema 2: Mover para fora do ScrollingFrame)
    Utils.Create("Frame", { 
        Name = "SidebarBorder",
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(0, Config.Window.SidebarWidth - 1, 0, 0),
