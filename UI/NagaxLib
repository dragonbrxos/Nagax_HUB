        Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        Parent = self.Instance
    })
    Utils.RoundCorners(self.Input, 4)
    Utils.AddStroke(self.Input, 1, NagaxLib.Theme.Colors.Border)
    
    self:Connect(self.Input.FocusLost, function(enterPressed)
        if callback then
            task.spawn(function() pcall(callback, self.Input.Text, enterPressed) end)
        end
    end)
    
    return self
end

-- ── SISTEMA DE TABS & SECTIONS ───────────────────────────────
local TabSystem = {}

function TabSystem:Create(window, name)
    local tab = {
        Window = window,
        Name = name,
        Sections = {},
        Active = false
    }
    
    -- Botão na Sidebar
    tab.Button = Utils.Create("TextButton", {
        Size = UDim2.new(0.9, 0, 0, 30),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        Text = name,
        TextColor3 = NagaxLib.Theme.Colors.Text.Secondary,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        AutoButtonColor = false,
        Parent = window.Sidebar
    })
    Utils.RoundCorners(tab.Button, 6)
    
    tab.Button.MouseButton1Click:Connect(function()
        window:SelectTab(tab)
    end)
    
    -- Container de Conteúdo
    tab.Scroll = Utils.Create("ScrollingFrame", {
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = NagaxLib.Theme.Colors.Accent.Dark,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = window.MainPanel
    })
    
    Utils.Create("UIListLayout", {
        Padding = UDim.new(0, 10),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        Parent = tab.Scroll
    })
    
    function tab:Section(title)
        local section = {Title = title}
        
        local container = Utils.Create("Frame", {
            Size = UDim2.new(1, 0, 0, 30),
            BackgroundTransparency = 1,
            AutomaticSize = Enum.AutomaticSize.Y,
            Parent = tab.Scroll
        })
        
        local layout = Utils.Create("UIListLayout", {
            Padding = UDim.new(0, 6),
            Parent = container
        })
        
        if title then
            Utils.Create("TextLabel", {
                Size = UDim2.new(1, 0, 0, 20),
                BackgroundTransparency = 1,
                Text = title:upper(),
                TextColor3 = NagaxLib.Theme.Colors.Accent.Primary,
                TextSize = 10,
                Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = container
            })
        end
        
        -- Métodos da Section
        function section:Toggle(label, default, callback)
            return ToggleComponent:Create(container, label, default, callback)
        end
        
        function section:Button(label, callback)
            return ButtonComponent:Create(container, label, callback)
        end
        
        function section:Slider(label, min, max, default, callback)
            return SliderComponent:Create(container, label, min, max, default, callback)
        end
        
        function section:Dropdown(label, options, default, callback)
            return DropdownComponent:Create(container, label, options, default, callback)
        end
        
        function section:Input(label, placeholder, callback)
            return InputComponent:Create(container, label, placeholder, callback)
        end
        
        return section
    end
    
    return tab
end

