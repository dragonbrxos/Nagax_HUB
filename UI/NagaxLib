-- ── UTILITÁRIOS OTIMIZADOS ───────────────────────────────────
local Utils = {}

function Utils.Create(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        if prop ~= "Parent" then
            instance[prop] = value
        end
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utils.Tween(instance, properties, duration, callback)
    duration = duration or Config.Animation.Duration
    local tween = Services.TweenService:Create(
        instance, 
        TweenInfo.new(duration, Config.Animation.Style, Config.Animation.Direction),
        properties
    )
    if callback then
        tween.Completed:Connect(callback)
    end
    tween:Play()
    return tween
end

function Utils.RoundCorners(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = instance
    return corner
end

function Utils.AddStroke(instance, thickness, color, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness or 1
    stroke.Color = color or NagaxLib.Theme.Colors.Border
    stroke.Transparency = transparency or 0
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = instance
    return stroke
end

function Utils.CopyTable(tbl)
    local copy = {}
    for k, v in pairs(tbl) do
        if type(v) == "table" then
            copy[k] = Utils.CopyTable(v)
        else
            copy[k] = v
        end
    end
    return copy
end

-- ── SISTEMA DE OVERLAY (DROPDOWNS FLUTUANTES) ────────────────
NagaxLib.Overlay = {
    Gui = nil,
    ActiveDropdown = nil,
    
    Init = function()
        if NagaxLib.Overlay.Gui then return end
        
        NagaxLib.Overlay.Gui = Utils.Create("ScreenGui", {
            Name = "NagaxLibOverlay",
            Parent = PlayerGui,
            ZIndexBehavior = Enum.ZIndexBehavior.Global,
            DisplayOrder = Config.ZIndex.Overlay,
            ResetOnSpawn = false,
            IgnoreGuiInset = true
        })
        
        -- Fecha dropdown ao clicar fora
        Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 or 
               input.UserInputType == Enum.UserInputType.Touch then
                
                if NagaxLib.Overlay.ActiveDropdown then
                    local mousePos = Services.UserInputService:GetMouseLocation()
                    local dropdown = NagaxLib.Overlay.ActiveDropdown
                    
                    -- Verifica se clicou fora do dropdown
                    if dropdown.Frame then
                        local pos = dropdown.Frame.AbsolutePosition
                        local size = dropdown.Frame.AbsoluteSize
                        
                        if mousePos.X < pos.X or mousePos.X > pos.X + size.X or
                           mousePos.Y < pos.Y or mousePos.Y > pos.Y + size.Y then
                            dropdown:Close()
                        end
                    end
                end
            end
        end)
    end,
    
    RegisterDropdown = function(dropdownObj)
        if NagaxLib.Overlay.ActiveDropdown and NagaxLib.Overlay.ActiveDropdown ~= dropdownObj then
            NagaxLib.Overlay.ActiveDropdown:Close()
        end
        NagaxLib.Overlay.ActiveDropdown = dropdownObj
    end,
    
    ClearDropdown = function()
        NagaxLib.Overlay.ActiveDropdown = nil
    end
}

-- ── CLASSE BASE DE COMPONENTES ───────────────────────────────
local ComponentBase = {}
ComponentBase.__index = ComponentBase

function ComponentBase.new(type, parent)
    local self = setmetatable({}, ComponentBase)
    self.Type = type
    self.Parent = parent
    self.ThemeId = type .. "_" .. tostring(math.random(100000))
    self.Instance = nil
    self._connections = {}
    return self
end

function ComponentBase:Connect(event, callback)
    local conn = event:Connect(callback)
    table.insert(self._connections, conn)
    return conn
end

function ComponentBase:Destroy()
    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    if self.Instance then
        self.Instance:Destroy()
    end
    NagaxLib.Theme.RemoveListener(self.ThemeId)
end

function ComponentBase:UpdateTheme(category, key, color)
    -- Sobrescrito por componentes específicos
end

