        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        Text = name,
        TextColor3 = NagaxLib.Theme.Colors.Text.Secondary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
        LayoutOrder = #window.Tabs + 1,
        Parent = window.Sidebar
    })
    Utils.RoundCorners(self.Button, 7)
    
    Utils.Create("UIPadding", {
        PaddingLeft = UDim.new(0, 10),
        Parent = self.Button
    })
    
    -- Container Scroll
    self.Scroll = Utils.Create("ScrollingFrame", {
        Name = "Scroll_" .. name,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = NagaxLib.Theme.Colors.Accent.Dark,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = window.MainPanel
    })
    
    Utils.Create("UIPadding", {
        PaddingTop = UDim.new(0, 8),
        PaddingBottom = UDim.new(0, 8),
        PaddingLeft = UDim.new(0, 8),
        PaddingRight = UDim.new(0, 10),
        Parent = self.Scroll
    })
    
    Utils.Create("UIListLayout", {
        Padding = UDim.new(0, 4),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        Parent = self.Scroll
    })
    
    -- Eventos
    self.Button.MouseEnter:Connect(function()
        if window.ActiveTab ~= self then
            Utils.Tween(self.Button, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary}, 0.1)
        end
    end)
    
    self.Button.MouseLeave:Connect(function()
        if window.ActiveTab ~= self then
            Utils.Tween(self.Button, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary}, 0.1)
        end
    end)
    
    self.Button.MouseButton1Click:Connect(function()
        window:SelectTab(self)
    end)
    
    return self
end

-- Métodos de criação de componentes (API Pública)
function TabSystem:Toggle(label, default, callback)
    local toggle = ToggleComponent:Create(self.Scroll, label, default, callback)
    table.insert(self.Components, toggle)
    return toggle
end

function TabSystem:Slider(label, min, max, default, callback, precise)
    local slider = SliderComponent:Create(self.Scroll, label, min, max, default, callback, precise)
    table.insert(self.Components, slider)
    return slider
end

function TabSystem:Dropdown(label, options, callback)
    local dropdown = DropdownComponent:Create(self.Scroll, label, options, callback)
    table.insert(self.Components, dropdown)
    return dropdown
end

function TabSystem:Button(label, callback)
    local btn = ButtonComponent:Create(self.Scroll, label, callback)
    table.insert(self.Components, btn)
    return btn
end

function TabSystem:Label(text)
    local lbl = LabelComponent:Create(self.Scroll, text)
    table.insert(self.Components, lbl)
    return lbl
end

function TabSystem:Seperator(text)
    local sep = SeparatorComponent:Create(self.Scroll, text)
    table.insert(self.Components, sep)
    return sep
end
TabSystem.Separator = TabSystem.Seperator

function TabSystem:Line()
    return self:Seperator("")
end

