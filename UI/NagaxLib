            Size = UDim2.new(0, 180, 0, 220),
            Position = UDim2.new(1, -190, 0, Config.Window.HeaderHeight + 10),
            BackgroundColor3 = NagaxLib.Theme.Colors.Background.Secondary,
            ZIndex = 20,
            Parent = self.Main
        })
