-- TOGGLE (Atualizado com API padronizada)
local ToggleComponent = setmetatable({}, {__index = ComponentBase})
ToggleComponent.__index = ToggleComponent

function ToggleComponent:Create(parent, label, default, callback)
    local self = setmetatable(ComponentBase.new("Toggle", parent), ToggleComponent)
    
    self.State = default == true
    self.Callback = callback
    
    -- Container
    self.Instance = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
        BorderSizePixel = 0,
        Parent = parent
    })
    Utils.RoundCorners(self.Instance, 7)
    Utils.AddStroke(self.Instance, 1, NagaxLib.Theme.Colors.Border)
    
    -- Label
    self.Label = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -52, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = label or "",
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = self.Instance
    })
    
    -- Pill (Track)
    self.Pill = Utils.Create("Frame", {
        Size = UDim2.new(0, 36, 0, 18),
        Position = UDim2.new(1, -44, 0.5, -9),
        BackgroundColor3 = self.State and NagaxLib.Theme.Colors.State.On or NagaxLib.Theme.Colors.State.Off,
        BorderSizePixel = 0,
        Parent = self.Instance
    })
    Utils.RoundCorners(self.Pill, 9)
    
    -- Knob
    self.Knob = Utils.Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = self.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
        BackgroundColor3 = NagaxLib.Theme.Colors.Text.Primary,
        BorderSizePixel = 0,
        Parent = self.Pill
    })
    Utils.RoundCorners(self.Knob, 7)
    
    -- Hitbox
    self.Hitbox = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 3,
        Parent = self.Instance
    })
    
    -- Interação
    self:Connect(self.Hitbox.MouseEnter, function()
        Utils.Tween(self.Instance, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Hover}, 0.1)
    end)
    
    self:Connect(self.Hitbox.MouseLeave, function()
        Utils.Tween(self.Instance, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary}, 0.1)
    end)
    
    self:Connect(self.Hitbox.MouseButton1Click, function()
        self:SetValue(not self.State)
    end)
    
    -- Tema reativo
    NagaxLib.Theme.OnUpdate(self.ThemeId, function(cat, key, color)
        if cat == "State" and key == "On" and self.State then
            self.Pill.BackgroundColor3 = color
        elseif cat == "State" and key == "Off" and not self.State then
            self.Pill.BackgroundColor3 = color
        elseif cat == "Text" and key == "Primary" then
            self.Knob.BackgroundColor3 = color
            self.Label.TextColor3 = color
        end
    end)
    
    -- Callback inicial
    if self.Callback and self.State then
        task.spawn(self.Callback, self.State)
    end
    
    return self
end

function ToggleComponent:SetValue(value)
    if self.State == value then return end
    self.State = value
    
    local targetColor = self.State and NagaxLib.Theme.Colors.State.On or NagaxLib.Theme.Colors.State.Off
    Utils.Tween(self.Pill, {BackgroundColor3 = targetColor}, 0.15)
    Utils.Tween(self.Knob, {
        Position = self.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    }, 0.15)
    
    if self.Callback then
        task.spawn(self.Callback, self.State)
    end
end

function ToggleComponent:GetValue()
    return self.State
end

-- SLIDER (Otimizado - só processa input quando necessário)
local SliderComponent = setmetatable({}, {__index = ComponentBase})
SliderComponent.__index = SliderComponent

function SliderComponent:Create(parent, label, min, max, default, callback, precise)
    local self = setmetatable(ComponentBase.new("Slider", parent), SliderComponent)
    
    self.Min = min or 0
    self.Max = max or 100
    self.Value = math.clamp(default or self.Min, self.Min, self.Max)
    self.Callback = callback
    self.Precise = precise or false
    self.Dragging = false
    
    local range = self.Max - self.Min
    
    -- Container
    self.Instance = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
        BorderSizePixel = 0,
        Parent = parent
    })
    Utils.RoundCorners(self.Instance, 7)
    Utils.AddStroke(self.Instance, 1, NagaxLib.Theme.Colors.Border)
    
    -- Label
    self.Label = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -16, 0, 18),
        Position = UDim2.new(0, 8, 0, 4),
        BackgroundTransparency = 1,
        Text = (label or "") .. ": " .. tostring(self.Value),
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Instance
    })
    
    -- Track
    self.Track = Utils.Create("Frame", {
        Size = UDim2.new(1, -18, 0, 6),
        Position = UDim2.new(0, 9, 0, 30),
        BackgroundColor3 = NagaxLib.Theme.Colors.State.Off,
        BorderSizePixel = 0,
        Parent = self.Instance
    })
    Utils.RoundCorners(self.Track, 3)
    
    -- Fill
    local pct = (self.Value - self.Min) / range
    self.Fill = Utils.Create("Frame", {
        Size = UDim2.new(pct, 0, 1, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Accent.Primary,
        BorderSizePixel = 0,
        Parent = self.Track
    })
    Utils.RoundCorners(self.Fill, 3)
    
    -- Knob
    self.Knob = Utils.Create("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(pct, 0, 0.5, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Text.Primary,
        BorderSizePixel = 0,
        ZIndex = 3,
        Parent = self.Track
    })
    Utils.RoundCorners(self.Knob, 9)
    
    -- Hitbox (área maior para facilitar toque)
    self.Hitbox = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 4, 8),
        Position = UDim2.new(0, 0, 0, -10),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 5,
        Parent = self.Track
    })
    
    -- Lógica de arrasto otimizada
    self:Connect(self.Hitbox.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            self.Dragging = true
            self:UpdateFromInput(input.Position.X)
        end
    end)
    
    self:Connect(Services.UserInputService.InputChanged, function(input)
        if not self.Dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch then
            self:UpdateFromInput(input.Position.X)
        end
    end)
    
    self:Connect(Services.UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            self.Dragging = false
        end
    end)
    
    -- Tema
    NagaxLib.Theme.OnUpdate(self.ThemeId, function(cat, key, color)
        if cat == "Accent" and key == "Primary" then
            self.Fill.BackgroundColor3 = color
        elseif cat == "State" and key == "Off" then
            self.Track.BackgroundColor3 = color
        end
    end)
    
    if self.Callback then
        task.spawn(self.Callback, self.Value)
    end
    
    return self
end

function SliderComponent:UpdateFromInput(mouseX)
    local trackPos = self.Track.AbsolutePosition.X
    local trackWidth = self.Track.AbsoluteSize.X
    local pct = math.clamp((mouseX - trackPos) / math.max(trackWidth, 1), 0, 1)
    
    local rawValue = self.Min + (pct * (self.Max - self.Min))
    self.Value = self.Precise and rawValue or math.floor(rawValue + 0.5)
    
    self.Fill.Size = UDim2.new(pct, 0, 1, 0)
    self.Knob.Position = UDim2.new(pct, 0, 0.5, 0)
    self.Label.Text = self.Label.Text:gsub(": .*", ": " .. tostring(self.Value))
    
    if self.Callback then
        self.Callback(self.Value)
    end
end

function SliderComponent:SetValue(value)
    self.Value = math.clamp(value, self.Min, self.Max)
    local pct = (self.Value - self.Min) / (self.Max - self.Min)
    self.Fill.Size = UDim2.new(pct, 0, 1, 0)
    self.Knob.Position = UDim2.new(pct, 0, 0.5, 0)
    self.Label.Text = self.Label.Text:gsub(": .*", ": " .. tostring(self.Value))
    if self.Callback then
        self.Callback(self.Value)
    end
end

function SliderComponent:GetValue()
    return self.Value
end

