        Text = tostring(self.Selected or "None"),
        TextColor3 = NagaxLib.Theme.Colors.Accent.Primary,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = self.Instance
    })
    
    -- Icon
    self.Icon = Utils.Create("TextLabel", {
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -24, 0.5, -10),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = NagaxLib.Theme.Colors.Text.Tertiary,
        TextSize = 10,
        Font = Enum.Font.Gotham,
        Parent = self.Instance
    })
    
