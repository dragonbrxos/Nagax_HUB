        ln.BackgroundColor3 = C.bdr
        ln.BorderSizePixel  = 0
        ln.Parent           = f
    end

    -- ── TOGGLE ───────────────────────────────────────────────
    function tabObj:Toggle(labelText, default, callback)
        local state = (default == true)
        local row   = makeRow(34)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1,-52,1,0)
        lbl.Position              = UDim2.new(0,10,0,0)
        lbl.BackgroundTransparency= 1
        lbl.Text                  = labelText or ""
        lbl.TextColor3            = C.txt
        lbl.TextSize              = 11
        lbl.Font                  = Enum.Font.Gotham
        lbl.TextXAlignment        = Enum.TextXAlignment.Left
        lbl.TextWrapped           = true
        lbl.Parent                = row

        local pill = Instance.new("Frame")
        pill.Size             = UDim2.new(0,36,0,18)
        pill.Position         = UDim2.new(1,-44,0.5,-9)
        pill.BackgroundColor3 = state and C.on or C.off
        pill.BorderSizePixel  = 0
        pill.Parent           = row
        corner(pill, 9)

        local knob = Instance.new("Frame")
        knob.Size             = UDim2.new(0,14,0,14)
        knob.Position         = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
        knob.BackgroundColor3 = C.white
        knob.BorderSizePixel  = 0
        knob.Parent           = pill
        corner(knob, 7)

        local hit = Instance.new("TextButton")
        hit.Size                   = UDim2.new(1,0,1,0)
        hit.BackgroundTransparency = 1
        hit.Text                   = ""
        hit.ZIndex                 = 3
        hit.Parent                 = row

        local function refresh()
            pill.BackgroundColor3 = state and C.on or C.off
            knob.Position         = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
        end

        hit.MouseButton1Click:Connect(function()
            state = not state
            refresh()
            if callback then pcall(callback, state) end
        end)
        if callback and state then pcall(callback, state) end

        return {
            SetValue = function(_, v)
                state = v; refresh()
                if callback then pcall(callback, state) end
            end
        }
    end

    -- ── BUTTON ───────────────────────────────────────────────
    function tabObj:Button(labelText, callback)
        local row = makeRow(34)

        local b = Instance.new("TextButton")
        b.Size             = UDim2.new(1,-16,0,26)
        b.Position         = UDim2.new(0,8,0.5,-13)
        b.BackgroundColor3 = C.acc
        b.BorderSizePixel  = 0
        b.Text             = labelText or ""
        b.TextColor3       = C.white
        b.TextSize         = 11
        b.Font             = Enum.Font.GothamBold
        b.AutoButtonColor  = false
        b.ZIndex           = 2
        b.Parent           = row
        corner(b, 6)

        b.MouseEnter:Connect(function() tween(b,{BackgroundColor3=C.acc2}) end)
        b.MouseLeave:Connect(function() tween(b,{BackgroundColor3=C.acc}) end)
        b.MouseButton1Down:Connect(function() tween(b,{BackgroundColor3=C.acc3},0.05) end)
        b.MouseButton1Up:Connect(function() tween(b,{BackgroundColor3=C.acc},0.05) end)
        b.MouseButton1Click:Connect(function()
            if callback then pcall(callback) end
        end)
    end

    -- ── LABEL ────────────────────────────────────────────────
    function tabObj:Label(text)
        local row = makeRow(20, true)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1,-10,1,0)
        lbl.Position              = UDim2.new(0,6,0,0)
        lbl.BackgroundTransparency= 1
        lbl.Text                  = text or ""
        lbl.TextColor3            = C.txt2
        lbl.TextSize              = 10
        lbl.Font                  = Enum.Font.Gotham
        lbl.TextXAlignment        = Enum.TextXAlignment.Left
        lbl.TextWrapped           = true
        lbl.Parent                = row

        local obj = {}
        function obj:Set(t) lbl.Text = tostring(t or "") end
        return setmetatable(obj, {
            __newindex = function(_, k, v)
                if k == "Text" then lbl.Text = tostring(v or "") end
            end,
            __index = function(_, k)
                if k == "Text" then return lbl.Text end
            end,
        })
    end

    -- ── SLIDER (corrigido: nao arrasta janela) ────────────────
    function tabObj:Slider(labelText, minV, maxV, default, arg5, arg6)
        local callback
        if type(arg5) == "function" then callback = arg5
        elseif type(arg6) == "function" then callback = arg6 end
        minV  = minV or 0
        maxV  = maxV or 100
        local value = math.clamp(default or minV, minV, maxV)
        local range = math.max(maxV - minV, 1)

        local row = makeRow(50)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1,-10,0,18)
        lbl.Position              = UDim2.new(0,8,0,4)
        lbl.BackgroundTransparency= 1
        lbl.Text                  = (labelText or "") .. ":  " .. tostring(value)
        lbl.TextColor3            = C.txt
        lbl.TextSize              = 11
        lbl.Font                  = Enum.Font.Gotham
        lbl.TextXAlignment        = Enum.TextXAlignment.Left
        lbl.Parent                = row

        -- track
        local track = Instance.new("Frame")
        track.Size             = UDim2.new(1,-18,0,6)
        track.Position         = UDim2.new(0,9,0,30)
        track.BackgroundColor3 = C.off
        track.BorderSizePixel  = 0
        track.Parent           = row
        corner(track, 3)

        local pct0 = (value - minV) / range
        local fill = Instance.new("Frame")
        fill.Size             = UDim2.new(pct0,0,1,0)
        fill.BackgroundColor3 = C.acc
        fill.BorderSizePixel  = 0
        fill.Parent           = track
        corner(fill, 3)

        local knob = Instance.new("Frame")
        knob.Size             = UDim2.new(0,14,0,14)
        knob.AnchorPoint      = Vector2.new(0.5,0.5)
        knob.Position         = UDim2.new(pct0,0,0.5,0)
        knob.BackgroundColor3 = C.white
        knob.BorderSizePixel  = 0
        knob.ZIndex           = 3
        knob.Parent           = track
        corner(knob, 7)

        -- IMPORTANTE: area de hit maior, mas com ZIndex alto
        -- O slider usa InputBegan/InputEnded para nao conflitar com o drag da janela
        local draggingSlider = false

        local hit = Instance.new("TextButton")
        hit.Size                   = UDim2.new(1,0,3,4)
        hit.Position               = UDim2.new(0,0,0,-6)
        hit.BackgroundTransparency = 1
        hit.Text                   = ""
        hit.ZIndex                 = 5
        hit.Parent                 = track

        local function updateSlider(mx)
            local ax  = track.AbsolutePosition.X
            local aw  = track.AbsoluteSize.X
            local pct = math.clamp((mx - ax) / math.max(aw,1), 0, 1)
            value     = math.floor(minV + pct * range + 0.5)
            local v2  = (value - minV) / range
            fill.Size     = UDim2.new(v2, 0, 1, 0)
            knob.Position = UDim2.new(v2, 0, 0.5, 0)
            lbl.Text      = (labelText or "") .. ":  " .. tostring(value)
            if callback then pcall(callback, value) end
        end

        -- Usa InputBegan no hit para capturar o slider
        hit.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSlider = true
                updateSlider(inp.Position.X)
            end
        end)
        hit.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSlider = false
            end
        end)

        -- Move enquanto arrasta (apenas quando slider esta ativo)
        uis.InputChanged:Connect(function(inp)
            if draggingSlider and inp.UserInputType == Enum.UserInputType.MouseMovement then
                updateSlider(inp.Position.X)
            end
        end)
        uis.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSlider = false
            end
        end)

        if callback then pcall(callback, value) end
    end

    -- ── DROPDOWN ─────────────────────────────────────────────
    function tabObj:Dropdown(labelText, options, callback)
        options  = options or {}
        local selected = tostring(options[1] or "")
        local open     = false

        local container = Instance.new("Frame")
        container.Name             = "DD_"..(labelText or "")
        container.Size             = UDim2.new(1,0,0,34)
        container.BackgroundColor3 = C.bg4
        container.BorderSizePixel  = 0
        container.ClipsDescendants = false
        container.ZIndex           = 5
        container.LayoutOrder      = nextOrder()
        container.Parent           = scroll
        corner(container, 7)
        stroke(container, 1, C.bdr)

        local hdrDD = Instance.new("TextButton")
        hdrDD.Size                   = UDim2.new(1,0,0,34)
        hdrDD.BackgroundTransparency = 1
        hdrDD.BorderSizePixel        = 0
        hdrDD.Text                   = "v  " .. (labelText or "") .. ":  " .. selected
        hdrDD.TextColor3             = C.txt
        hdrDD.TextSize               = 11
        hdrDD.Font                   = Enum.Font.Gotham
        hdrDD.TextXAlignment         = Enum.TextXAlignment.Left
        hdrDD.AutoButtonColor        = false
        hdrDD.ZIndex                 = 6
        hdrDD.Parent                 = container

        local hdrPad = Instance.new("UIPadding")
        hdrPad.PaddingLeft = UDim.new(0,10)
        hdrPad.Parent      = hdrDD

        local optFrame = Instance.new("Frame")
        optFrame.Size             = UDim2.new(1,0,0,0)
        optFrame.Position         = UDim2.new(0,0,0,34)
        optFrame.BackgroundColor3 = C.bg2
        optFrame.BorderSizePixel  = 0
        optFrame.ClipsDescendants = true
        optFrame.ZIndex           = 15
        optFrame.Visible          = false
        optFrame.Parent           = container
        corner(optFrame, 6)
        stroke(optFrame, 1, C.bdr)

        local optPad = Instance.new("UIPadding")
        optPad.PaddingTop    = UDim.new(0,3)
        optPad.PaddingBottom = UDim.new(0,3)
        optPad.PaddingLeft   = UDim.new(0,3)
        optPad.PaddingRight  = UDim.new(0,3)
        optPad.Parent        = optFrame

        local optList = Instance.new("UIListLayout")
        optList.FillDirection = Enum.FillDirection.Vertical
        optList.Padding       = UDim.new(0,2)
        optList.Parent        = optFrame

        local function buildOpts(opts)
            for _, ch in ipairs(optFrame:GetChildren()) do
                if ch:IsA("TextButton") then ch:Destroy() end
            end
            for _, opt in ipairs(opts) do
                local ob = Instance.new("TextButton")
                ob.Size                   = UDim2.new(1,0,0,26)
                ob.BackgroundColor3       = C.bg3
                ob.BorderSizePixel        = 0
                ob.Text                   = tostring(opt)
                ob.TextColor3             = C.txt
                ob.TextSize               = 11
                ob.Font                   = Enum.Font.Gotham
                ob.TextXAlignment         = Enum.TextXAlignment.Left
                ob.AutoButtonColor        = false
                ob.ZIndex                 = 16
                ob.Parent                 = optFrame
                corner(ob, 5)

                local oPad = Instance.new("UIPadding")
                oPad.PaddingLeft = UDim.new(0,8)
                oPad.Parent      = ob

                ob.MouseEnter:Connect(function() tween(ob,{BackgroundColor3=C.bg4}) end)
                ob.MouseLeave:Connect(function() tween(ob,{BackgroundColor3=C.bg3}) end)
                ob.MouseButton1Click:Connect(function()
                    selected           = tostring(opt)
                    hdrDD.Text         = "v  " .. (labelText or "") .. ":  " .. selected
                    open               = false
                    optFrame.Visible   = false
                    container.Size     = UDim2.new(1,0,0,34)
                    if callback then pcall(callback, selected) end
                end)
            end
            optFrame.Size = UDim2.new(1,0,0,#opts*28+6)
        end

        buildOpts(options)

        hdrDD.MouseButton1Click:Connect(function()
            open           = not open
            optFrame.Visible = open
            container.Size = open
                and UDim2.new(1,0,0,34+#options*28+6)
                or  UDim2.new(1,0,0,34)
        end)

        if callback then pcall(callback, selected) end

        return {
            Refresh = function(_, newOpts)
                options  = newOpts or {}
                selected = tostring(options[1] or "")
                hdrDD.Text = "v  " .. (labelText or "") .. ":  " .. selected
                buildOpts(options)
                if callback then pcall(callback, selected) end
            end,
            Clear = function(_)
                options = {}
                for _, ch in ipairs(optFrame:GetChildren()) do
                    if ch:IsA("TextButton") then ch:Destroy() end
                end
                container.Size = UDim2.new(1,0,0,34)
                optFrame.Visible = false
                open = false
            end,
            Add = function(_, opt)
                table.insert(options, opt)
                buildOpts(options)
            end,
        }
    end

    -- ── TEXTBOX ──────────────────────────────────────────────
    function tabObj:TextBox(labelText, callback, clearOnFocus)
        local row = makeRow(50)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1,-10,0,18)
        lbl.Position              = UDim2.new(0,8,0,3)
        lbl.BackgroundTransparency= 1
        lbl.Text                  = labelText or ""
        lbl.TextColor3            = C.txt
        lbl.TextSize              = 11
        lbl.Font                  = Enum.Font.Gotham
        lbl.TextXAlignment        = Enum.TextXAlignment.Left
        lbl.Parent                = row

        local box = Instance.new("TextBox")
        box.Size             = UDim2.new(1,-16,0,22)
        box.Position         = UDim2.new(0,8,0,24)
        box.BackgroundColor3 = C.bg3
        box.BorderSizePixel  = 0
        box.Text             = ""
        box.PlaceholderText  = "Digite aqui..."
        box.PlaceholderColor3= C.txt3
        box.TextColor3       = C.txt
        box.TextSize         = 11
        box.Font             = Enum.Font.Gotham
        box.TextXAlignment   = Enum.TextXAlignment.Left
        box.ClearTextOnFocus = (clearOnFocus == true)
        box.ZIndex           = 3
        box.Parent           = row
        corner(box, 5)
        stroke(box, 1, C.bdr)

        box.Focused:Connect(function()
            tween(box, {}, 0.1) -- pode adicionar highlight
        end)
        box.FocusLost:Connect(function(enterPressed)
            if enterPressed and callback then
                pcall(callback, box.Text)
            end
        end)
    end

    -- Registrar tab
    btn.MouseButton1Click:Connect(function() selectTab(tabObj) end)
    table.insert(tabs, tabObj)
    if #tabs == 1 then
        activeTab                = tabObj
        btn.BackgroundColor3     = C.acc
        btn.TextColor3           = C.white
        btn:SetAttribute("active", true)
        scroll.Visible           = true
    end

    return tabObj
end

return NagaxLib
