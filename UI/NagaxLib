-- TOGGLE
local ToggleComponent = setmetatable({}, {__index = ComponentBase})
ToggleComponent.__index = ToggleComponent

function ToggleComponent:Create(parent, label, default, callback)
    local self = setmetatable(ComponentBase.new("Toggle", parent), ToggleComponent)
    self.State = default == true
    self.Callback = callback
    
    self.Instance = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
        BorderSizePixel = 0,
        Parent = parent
    })
    Utils.RoundCorners(self.Instance, 7)
    Utils.AddStroke(self.Instance, 1, NagaxLib.Theme.Colors.Border)
    
    self.Label = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -52, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = label or "",
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Instance
    })
    
    self.Pill = Utils.Create("Frame", {
        Size = UDim2.new(0, 36, 0, 18),
        Position = UDim2.new(1, -44, 0.5, -9),
        BackgroundColor3 = self.State and NagaxLib.Theme.Colors.State.On or NagaxLib.Theme.Colors.State.Off,
        BorderSizePixel = 0,
        Parent = self.Instance
    })
    Utils.RoundCorners(self.Pill, 9)
    
    self.Knob = Utils.Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = self.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
        BackgroundColor3 = NagaxLib.Theme.Colors.Text.Primary,
        BorderSizePixel = 0,
        Parent = self.Pill
    })
    Utils.RoundCorners(self.Knob, 7)
    
    local hitbox = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = self.Instance
    })
    
    hitbox.MouseButton1Click:Connect(function()
        self:Set(not self.State)
    end)
    
    return self
end

function ToggleComponent:Set(state)
    self.State = state
    local targetPos = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    local targetColor = state and NagaxLib.Theme.Colors.State.On or NagaxLib.Theme.Colors.State.Off
    Utils.Tween(self.Knob, {Position = targetPos}, 0.2)
    Utils.Tween(self.Pill, {BackgroundColor3 = targetColor}, 0.2)
    if self.Callback then task.spawn(self.Callback, self.State) end
end

-- SLIDER
local SliderComponent = setmetatable({}, {__index = ComponentBase})
SliderComponent.__index = SliderComponent

function SliderComponent:Create(parent, label, min, max, default, callback)
    local self = setmetatable(ComponentBase.new("Slider", parent), SliderComponent)
    self.Min = min or 0
    self.Max = max or 100
    self.Value = default or min
    self.Callback = callback
    
    self.Instance = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 48),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
        BorderSizePixel = 0,
        Parent = parent
    })
    Utils.RoundCorners(self.Instance, 7)
    Utils.AddStroke(self.Instance, 1, NagaxLib.Theme.Colors.Border)
    
    self.Label = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 10, 0, 6),
        BackgroundTransparency = 1,
        Text = (label or "Slider") .. ": " .. tostring(self.Value),
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Instance
    })
    
    local track = Utils.Create("Frame", {
        Size = UDim2.new(1, -20, 0, 4),
        Position = UDim2.new(0, 10, 0, 34),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        Parent = self.Instance
    })
    Utils.RoundCorners(track, 2)
    
    self.Fill = Utils.Create("Frame", {
        Size = UDim2.new((self.Value - self.Min) / (self.Max - self.Min), 0, 1, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Accent.Primary,
        BorderSizePixel = 0,
        Parent = track
    })
    Utils.RoundCorners(self.Fill, 2)
    
    local dragging = false
    local function update(input)
        local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(self.Min + (self.Max - self.Min) * pos)
        self:Set(val)
    end
    
    self.Instance.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)
    
    Services.UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)
    
    Services.UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return self
end

function SliderComponent:Set(val)
    self.Value = val
    self.Label.Text = self.Label.Text:gsub(": .*", ": " .. tostring(val))
    local pct = (val - self.Min) / (self.Max - self.Min)
    Utils.Tween(self.Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
    if self.Callback then task.spawn(self.Callback, val) end
end

