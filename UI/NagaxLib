-- TOGGLE (Atualizado com API padronizada)
local ToggleComponent = setmetatable({}, {__index = ComponentBase})
ToggleComponent.__index = ToggleComponent

function ToggleComponent:Create(parent, label, default, callback)
    local self = setmetatable(ComponentBase.new("Toggle", parent), ToggleComponent)
    
    self.State = default == true
    self.Callback = callback
    
    -- Container
    self.Instance = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
        BorderSizePixel = 0,
        Parent = parent
    })
    Utils.RoundCorners(self.Instance, 7)
    Utils.AddStroke(self.Instance, 1, NagaxLib.Theme.Colors.Border)
    
    -- Label
    self.Label = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -52, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = label or "",
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = self.Instance
    })
    
    -- Pill (Track)
    self.Pill = Utils.Create("Frame", {
        Size = UDim2.new(0, 36, 0, 18),
        Position = UDim2.new(1, -44, 0.5, -9),
        BackgroundColor3 = self.State and NagaxLib.Theme.Colors.State.On or NagaxLib.Theme.Colors.State.Off,
        BorderSizePixel = 0,
        Parent = self.Instance
    })
    Utils.RoundCorners(self.Pill, 9)
    
    -- Knob
    self.Knob = Utils.Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = self.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
        BackgroundColor3 = NagaxLib.Theme.Colors.Text.Primary,
        BorderSizePixel = 0,
        Parent = self.Pill
    })
    Utils.RoundCorners(self.Knob, 7)
    
    -- Hitbox
    self.Hitbox = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 3,
        Parent = self.Instance
    })
    
    -- Interação
    self:Connect(self.Hitbox.MouseEnter, function()
        Utils.Tween(self.Instance, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Hover}, 0.15)
    end)
    
    self:Connect(self.Hitbox.MouseLeave, function()
        Utils.Tween(self.Instance, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary}, 0.15)
    end)
    
    self:Connect(self.Hitbox.MouseButton1Click, function()
        self:Set(not self.State)
    end)
    
    -- Registro de Tema
    NagaxLib.Theme.OnUpdate(self.ThemeId, function(cat, key, color)
        if cat == "Background" and key == "Quaternary" then
            self.Instance.BackgroundColor3 = color
        elseif cat == "Text" and key == "Primary" then
            self.Label.TextColor3 = color
            self.Knob.BackgroundColor3 = color
        elseif cat == "State" then
            if key == "On" and self.State then
                self.Pill.BackgroundColor3 = color
            elseif key == "Off" and not self.State then
                self.Pill.BackgroundColor3 = color
            end
        end
    end)
    
    return self
end

function ToggleComponent:Set(state)
    self.State = state
    local targetPos = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    local targetColor = state and NagaxLib.Theme.Colors.State.On or NagaxLib.Theme.Colors.State.Off
    
    Utils.Tween(self.Knob, {Position = targetPos}, 0.2)
    Utils.Tween(self.Pill, {BackgroundColor3 = targetColor}, 0.2)
    
    if self.Callback then
        task.spawn(function()
            local success, err = pcall(self.Callback, self.State)
            if not success then warn("Toggle Callback Error: " .. tostring(err)) end
        end)
    end
end

-- SLIDER (API padronizada)
local SliderComponent = setmetatable({}, {__index = ComponentBase})
SliderComponent.__index = SliderComponent

function SliderComponent:Create(parent, label, min, max, default, callback)
    local self = setmetatable(ComponentBase.new("Slider", parent), SliderComponent)
    
    self.Min = min or 0
    self.Max = max or 100
    self.Value = default or min
    self.Callback = callback
    
    -- Container
    self.Instance = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 48),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
        BorderSizePixel = 0,
        Parent = parent
    })
    Utils.RoundCorners(self.Instance, 7)
    Utils.AddStroke(self.Instance, 1, NagaxLib.Theme.Colors.Border)
    
    -- Label
    self.Label = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 10, 0, 6),
        BackgroundTransparency = 1,
        Text = label or "",
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Instance
    })
    
    -- Value Display
    self.ValueLabel = Utils.Create("TextLabel", {
        Size = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -50, 0, 6),
        BackgroundTransparency = 1,
        Text = tostring(self.Value),
        TextColor3 = NagaxLib.Theme.Colors.Accent.Primary,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = self.Instance
    })
    
    -- Track
    self.Track = Utils.Create("Frame", {
        Size = UDim2.new(1, -20, 0, 4),
        Position = UDim2.new(0, 10, 0, 34),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        Parent = self.Instance
    })
    Utils.RoundCorners(self.Track, 2)
    
    -- Fill
    self.Fill = Utils.Create("Frame", {
        Size = UDim2.new((self.Value - self.Min) / (self.Max - self.Min), 0, 1, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Accent.Primary,
        BorderSizePixel = 0,
        Parent = self.Track
    })
    Utils.RoundCorners(self.Fill, 2)
    
    -- Knob
    self.Knob = Utils.Create("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(1, -6, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = NagaxLib.Theme.Colors.Text.Primary,
        BorderSizePixel = 0,
        Parent = self.Fill
    })
    Utils.RoundCorners(self.Knob, 6)
    Utils.AddStroke(self.Knob, 2, NagaxLib.Theme.Colors.Accent.Primary)
    
    -- Dragging Logic
    local dragging = false
    
    local function update(input)
        local pos = math.clamp((input.Position.X - self.Track.AbsolutePosition.X) / self.Track.AbsoluteSize.X, 0, 1)
        local newValue = math.floor(self.Min + (self.Max - self.Min) * pos)
        self:Set(newValue)
    end
    
    self:Connect(self.Instance.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(input)
        end
    end)
    
    self:Connect(Services.UserInputService.InputChanged, function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                       input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)
    
    self:Connect(Services.UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    return self
end

function SliderComponent:Set(value)
    self.Value = math.clamp(value, self.Min, self.Max)
    self.ValueLabel.Text = tostring(self.Value)
    
    local percent = (self.Value - self.Min) / (self.Max - self.Min)
    Utils.Tween(self.Fill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.1)
    
    if self.Callback then
        task.spawn(function()
            pcall(self.Callback, self.Value)
        end)
    end
end

