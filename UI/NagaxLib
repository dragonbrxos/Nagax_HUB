-- Tab System
local Tabs = {}
local ActiveTab = nil

local function SelectTab(tabObj)
    if ActiveTab == tabObj then return end
    
    if ActiveTab then
        Tween(ActiveTab.Button, {BackgroundColor3 = C.bg3})
        ActiveTab.Button.TextColor3 = C.txt2
        ActiveTab.Button:SetAttribute("Active", false)
        ActiveTab.Content.Visible = false
    end
    
    ActiveTab = tabObj
    Tween(tabObj.Button, {BackgroundColor3 = C.acc})
    tabObj.Button.TextColor3 = C.white
    tabObj.Button:SetAttribute("Active", true)
    tabObj.Content.Visible = true
end

-- Tab Creation Function
function NagaxLib:Tab(name)
    local tabOrder = #Tabs + 1
    
    -- Sidebar Button
    local btn = Create("TextButton", {
        Name = "Tab_" .. name,
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = C.bg3,
        BorderSizePixel = 0,
        Text = name,
        TextColor3 = C.txt2,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
        LayoutOrder = tabOrder,
        Parent = Sidebar
    })
    Corner(btn, 8)
    
    Create("UIPadding", {
        PaddingLeft = UDim.new(0, 12),
        Parent = btn
    })
    
    btn.MouseEnter:Connect(function()
        if not (ActiveTab and ActiveTab.Button == btn) then
            Tween(btn, {BackgroundColor3 = C.bg4})
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if not (ActiveTab and ActiveTab.Button == btn) then
            Tween(btn, {BackgroundColor3 = C.bg3})
        end
    end)
    
    -- Content Container
    local content = Create("ScrollingFrame", {
        Name = "Content_" .. name,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = C.acc3,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ElasticBehavior = Enum.ElasticBehavior.Never,
        Visible = false,
        Parent = MainPanel
    })
    
    Create("UIPadding", {
        PaddingTop = UDim2.new(0, 10),
        PaddingBottom = UDim2.new(0, 10),
        PaddingLeft = UDim2.new(0, 10),
        PaddingRight = UDim2.new(0, 10),
        Parent = content
    })
    
    local contentList = Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Vertical,
        Padding = UDim.new(0, 6),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = content
    })
    
    local TabObj = {
        Button = btn,
        Content = content,
        Order = 0
    }
    
    function TabObj:GetOrder()
        self.Order = self.Order + 1
        return self.Order
    end
    
    function TabObj:CreateContainer(height, transparent)
        local container = Create("Frame", {
            Size = UDim2.new(1, 0, 0, height or 36),
