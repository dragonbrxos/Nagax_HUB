            local btn = Utils.Create("TextButton", {
                Size = UDim2.new(1, -10, 0, 25),
                BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary,
                Text = t.Name,
                TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
                TextSize = 10,
                Font = Enum.Font.Gotham,
                Parent = themeList
            })
            Utils.RoundCorners(btn, 4)
            btn.MouseButton1Click:Connect(function()
                NagaxLib.Theme.Set("Accent", "Primary", t.Color)
            end)
        end
    end)
    
    -- Body (Corrigido - Problema 1: Altura ajustada para liberar a StatusBar)
    local body = Utils.Create("Frame", {
        Name = "Body",
        Size = UDim2.new(1, 0, 1, -(Config.Window.HeaderHeight + Config.Window.StatusHeight)),
        Position = UDim2.new(0, 0, 0, Config.Window.HeaderHeight),
