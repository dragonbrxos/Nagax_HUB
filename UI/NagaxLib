        lineL.Position         = UDim2.new(0,0,0.5,0)
        lineL.BackgroundColor3 = C.acc3
        lineL.BorderSizePixel  = 0
        lineL.Parent           = f

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(0.44,0,1,0)
        lbl.Position              = UDim2.new(0.28,0,0,0)
        lbl.BackgroundTransparency= 1
        lbl.Text                  = text or ""
        lbl.TextColor3            = C.sep
        lbl.TextSize              = 9
        lbl.Font                  = Enum.Font.GothamBold
        lbl.TextXAlignment        = Enum.TextXAlignment.Center
        lbl.Parent                = f

        local lineR = Instance.new("Frame")
        lineR.Size             = UDim2.new(0.28,-4,0,1)
        lineR.Position         = UDim2.new(0.72,4,0.5,0)
        lineR.BackgroundColor3 = C.acc3
        lineR.BorderSizePixel  = 0
        lineR.Parent           = f
    end
    tabObj.Separator = tabObj.Seperator

    -- ── LINE ─────────────────────────────────────────────────
    function tabObj:Line()
        local f = Instance.new("Frame")
