            BackgroundTransparency = transparent and 1 or 0,
            BorderSizePixel = 0,
            LayoutOrder = self:GetOrder(),
            Parent = content
        })
        Corner(container, 8)
        if not transparent then
            Stroke(container, 1, C.bdr)
        end
        return container
    end
    
    -- Separator
