-- ── SISTEMA DE TABS ──────────────────────────────────────────
local TabSystem = {}

function TabSystem:Create(window, name)
    local tab = {
        Window = window,
        Name = name,
        Components = {}
    }
    
    tab.Button = Utils.Create("TextButton", {
        Size = UDim2.new(0.9, 0, 0, 30),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        Text = name,
        TextColor3 = NagaxLib.Theme.Colors.Text.Secondary,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        AutoButtonColor = false,
        Parent = window.Sidebar
    })
    Utils.RoundCorners(tab.Button, 6)
    
    tab.Scroll = Utils.Create("ScrollingFrame", {
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = NagaxLib.Theme.Colors.Accent.Dark,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = window.MainPanel
    })
    
    Utils.Create("UIListLayout", {
        Padding = UDim.new(0, 8),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        Parent = tab.Scroll
    })
    
    tab.Button.MouseButton1Click:Connect(function()
        window:SelectTab(tab)
    end)
    
    function tab:Toggle(label, default, callback) return ToggleComponent:Create(tab.Scroll, label, default, callback) end
    function tab:Slider(label, min, max, default, callback) return SliderComponent:Create(tab.Scroll, label, min, max, default, callback) end
    function tab:Button(label, callback) return ButtonComponent:Create(tab.Scroll, label, callback) end
    function tab:Section(title) return tab end
    
    return tab
end

-- ── JANELA PRINCIPAL (Window) ────────────────────────────────
local Window = {}
Window.__index = Window

function NagaxLib:CreateWindow(options)
    local self = setmetatable({}, Window)
    self.Title = options.Title or "Nagax Hub"
    self.Tabs = {}
    self.ActiveTab = nil
    
    self.Gui = Utils.Create("ScreenGui", {
        Name = "NagaxLib_" .. self.Title,
        Parent = PlayerGui,
        ResetOnSpawn = false
    })
    
    self.Main = Utils.Create("Frame", {
        Name = "Main",
        Size = UDim2.new(0, options.Width or Config.Window.Width, 0, options.Height or Config.Window.Height),
        Position = UDim2.new(0.5, -(options.Width or Config.Window.Width)/2, 0.5, -(options.Height or Config.Window.Height)/2),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Primary,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = self.Gui
    })
    Utils.RoundCorners(self.Main, Config.Window.CornerRadius)
    Utils.AddStroke(self.Main, 1, NagaxLib.Theme.Colors.Border)
    
    self.Header = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, Config.Window.HeaderHeight),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Secondary,
        BorderSizePixel = 0,
        Parent = self.Main
    })
    
    Utils.Create("TextLabel", {
        Size = UDim2.new(1, -100, 1, 0),
        Position = UDim2.new(0, 15, 0, 0),
        BackgroundTransparency = 1,
        Text = self.Title,
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Header
    })
    
    local closeBtn = Utils.Create("TextButton", {
        Size = UDim2.new(0, 26, 0, 20),
        Position = UDim2.new(1, -34, 0.5, -10),
        BackgroundColor3 = NagaxLib.Theme.Colors.State.Error,
        Text = "×",
        TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
        Parent = self.Header
    })
    Utils.RoundCorners(closeBtn, 5)
    closeBtn.MouseButton1Click:Connect(function() self.Gui:Destroy() end)
    
    local body = Utils.Create("Frame", {
        Name = "Body",
        Size = UDim2.new(1, 0, 1, -(Config.Window.HeaderHeight + Config.Window.StatusHeight)),
        Position = UDim2.new(0, 0, 0, Config.Window.HeaderHeight),
        BackgroundTransparency = 1,
        Parent = self.Main
    })
    
    self.Sidebar = Utils.Create("ScrollingFrame", {
        Size = UDim2.new(0, Config.Window.SidebarWidth, 1, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Secondary,
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent = body
    })
    Utils.Create("UIListLayout", {Padding = UDim.new(0, 2), HorizontalAlignment = Enum.HorizontalAlignment.Center, Parent = self.Sidebar})
    
    Utils.Create("Frame", {
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(0, Config.Window.SidebarWidth - 1, 0, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Accent.Dark,
        BorderSizePixel = 0,
        Parent = body
    })
    
    self.MainPanel = Utils.Create("Frame", {
        Size = UDim2.new(1, -Config.Window.SidebarWidth, 1, 0),
        Position = UDim2.new(0, Config.Window.SidebarWidth, 0, 0),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        Parent = body
    })
    
    local statusBar = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, Config.Window.StatusHeight),
        Position = UDim2.new(0, 0, 1, -Config.Window.StatusHeight),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Secondary,
        Parent = self.Main
    })
    
    local dragging, dragStart, startPos
    self.Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = self.Main.Position
        end
    end)
    Services.UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    Services.UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    return self
end

function Window:SelectTab(tab)
    if self.ActiveTab then
        self.ActiveTab.Button.BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary
        self.ActiveTab.Scroll.Visible = false
    end
    self.ActiveTab = tab
    tab.Button.BackgroundColor3 = NagaxLib.Theme.Colors.Accent.Primary
    tab.Scroll.Visible = true
end

function Window:Tab(name)
    local tab = TabSystem:Create(self, name)
    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then self:SelectTab(tab) end
    return tab
end

function Window:Init() end

return NagaxLib
