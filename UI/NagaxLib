    OnUpdate = function(id, callback)
        NagaxLib._themeCallbacks[id] = callback
    end,
    
    -- Remove registro
    RemoveListener = function(id)
        NagaxLib._themeCallbacks[id] = nil
    end,
    
    _propagate = function(cat, key, color)
        for id, callback in pairs(NagaxLib._themeCallbacks) do
            task.spawn(function()
                callback(cat, key, color)
            end)
        end
    end
