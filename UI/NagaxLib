    TabObj.Separator = TabObj.Seperator
    
    -- Toggle
    function TabObj:Toggle(label, default, callback)
        local container = self:CreateContainer(36)
        local state = default == true
        
        Create("TextLabel", {
            Size = UDim2.new(1, -60, 1, 0),
            Position = UDim2.new(0, 12, 0, 0),
            BackgroundTransparency = 1,
            Text = label,
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = container
        })
        
        local pill = Create("Frame", {
            Size = UDim2.new(0, 40, 0, 20),
            Position = UDim2.new(1, -48, 0.5, -10),
            BackgroundColor3 = state and C.on or C.off,
            BorderSizePixel = 0,
            Parent = container
        })
        Corner(pill, 10)
        
        local knob = Create("Frame", {
            Size = UDim2.new(0, 16, 0, 16),
            Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
            BackgroundColor3 = C.white,
            BorderSizePixel = 0,
            Parent = pill
        })
        Corner(knob, 8)
        
        local hit = Create("TextButton", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            Parent = container
        })
        
        local function refresh()
            pill.BackgroundColor3 = state and C.on or C.off
            knob.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        end
        
        hit.MouseButton1Click:Connect(function()
            state = not state
            refresh()
            if callback then pcall(callback, state) end
        end)
        
        if callback and state then pcall(callback, state) end
        
        return {
            SetValue = function(_, v)
                state = v
                refresh()
                if callback then pcall(callback, state) end
            end
        }
    end
    
    -- Button
    function TabObj:Button(label, callback)
        local container = self:CreateContainer(36)
        
        local btn = Create("TextButton", {
            Size = UDim2.new(1, -16, 0, 28),
            Position = UDim2.new(0, 8, 0.5, -14),
            BackgroundColor3 = C.acc,
            BorderSizePixel = 0,
            Text = label,
            TextColor3 = C.white,
            TextSize = 11,
            Font = Enum.Font.GothamBold,
            AutoButtonColor = false,
            Parent = container
        })
        Corner(btn, 6)
        
        btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = C.acc2}) end)
        btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = C.acc}) end)
        btn.MouseButton1Down:Connect(function() Tween(btn, {BackgroundColor3 = C.acc3}, 0.05) end)
        btn.MouseButton1Up:Connect(function() Tween(btn, {BackgroundColor3 = C.acc}, 0.05) end)
        btn.MouseButton1Click:Connect(function()
            if callback then pcall(callback) end
        end)
    end
    
    -- Label
    function TabObj:Label(text)
        local container = self:CreateContainer(24, true)
        
        local lbl = Create("TextLabel", {
            Size = UDim2.new(1, -12, 1, 0),
            Position = UDim2.new(0, 6, 0, 0),
            BackgroundTransparency = 1,
            Text = text or "",
            TextColor3 = C.txt2,
            TextSize = 10,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            Parent = container
        })
        
        return {
            Set = function(_, txt) lbl.Text = tostring(txt) end,
            Text = lbl.Text
        }
    end
    
    -- Slider
    function TabObj:Slider(label, min, max, default, callback)
        min = min or 0
        max = max or 100
        local value = math.clamp(default or min, min, max)
        local range = math.max(max - min, 1)
        
        local container = self:CreateContainer(52)
        
        local labelText = Create("TextLabel", {
            Size = UDim2.new(1, -12, 0, 20),
            Position = UDim2.new(0, 6, 0, 4),
            BackgroundTransparency = 1,
            Text = label .. ": " .. value,
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = container
        })
        
        local track = Create("Frame", {
            Size = UDim2.new(1, -20, 0, 6),
            Position = UDim2.new(0, 10, 0, 32),
            BackgroundColor3 = C.off,
            BorderSizePixel = 0,
            Parent = container
        })
        Corner(track, 3)
        
        local pct = (value - min) / range
        local fill = Create("Frame", {
            Size = UDim2.new(pct, 0, 1, 0),
            BackgroundColor3 = C.acc,
            BorderSizePixel = 0,
            Parent = track
        })
        Corner(fill, 3)
        
        local knob = Create("Frame", {
            Size = UDim2.new(0, 16, 0, 16),
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(pct, 0, 0.5, 0),
            BackgroundColor3 = C.white,
            BorderSizePixel = 0,
            ZIndex = 3,
            Parent = track
        })
        Corner(knob, 8)
        
        local dragging = false
        
        local function update(input)
            local pos = input.Position.X
            local trackPos = track.AbsolutePosition.X
            local trackSize = track.AbsoluteSize.X
            local newPct = math.clamp((pos - trackPos) / trackSize, 0, 1)
            local newVal = math.floor(min + (newPct * range) + 0.5)
            
            value = newVal
            fill.Size = UDim2.new(newPct, 0, 1, 0)
            knob.Position = UDim2.new(newPct, 0, 0.5, 0)
            labelText.Text = label .. ": " .. value
            
            if callback then pcall(callback, value) end
        end
        
        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                update(input)
            end
        end)
        
        UIS.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                update(input)
            end
        end)
        
        UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        if callback then pcall(callback, value) end
    end
    
    -- Dropdown
    function TabObj:Dropdown(label, options, callback)
        options = options or {}
        local selected = tostring(options[1] or "")
        local open = false
        
        local container = Create("Frame", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = C.bg4,
            BorderSizePixel = 0,
            ClipsDescendants = false,
            ZIndex = 5,
            LayoutOrder = self:GetOrder(),
            Parent = content
        })
        Corner(container, 8)
        Stroke(container, 1, C.bdr)
        
        local header = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1,
            Text = "v  " .. label .. ":  " .. selected,
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
            ZIndex = 6,
            Parent = container
        })
        
        Create("UIPadding", {
            PaddingLeft = UDim.new(0, 12),
            Parent = header
        })
        
        local dropdownFrame = Create("Frame", {
            Size = UDim2.new(1, 0, 0, 0),
            Position = UDim2.new(0, 0, 0, 38),
            BackgroundColor3 = C.bg2,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = 20,
            Visible = false,
            Parent = container
        })
        Corner(dropdownFrame, 6)
        Stroke(dropdownFrame, 1, C.bdr)
        
        Create("UIPadding", {
            PaddingTop = UDim.new(0, 4),
            PaddingBottom = UDim.new(0, 4),
            PaddingLeft = UDim.new(0, 4),
            PaddingRight = UDim.new(0, 4),
            Parent = dropdownFrame
        })
        
        local optsList = Create("UIListLayout", {
            FillDirection = Enum.FillDirection.Vertical,
            Padding = UDim.new(0, 2),
            Parent = dropdownFrame
        })
        
        local function buildOptions()
            for _, child in ipairs(dropdownFrame:GetChildren()) do
                if child:IsA("TextButton") then child:Destroy() end
            end
            
            for _, opt in ipairs(options) do
                local btn = Create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 28),
                    BackgroundColor3 = C.bg3,
                    BorderSizePixel = 0,
                    Text = tostring(opt),
                    TextColor3 = C.txt,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    AutoButtonColor = false,
                    ZIndex = 21,
                    Parent = dropdownFrame
                })
                Corner(btn, 5)
                
                Create("UIPadding", {
                    PaddingLeft = UDim.new(0, 10),
                    Parent = btn
                })
                
                btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = C.bg4}) end)
                btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = C.bg3}) end)
                
                btn.MouseButton1Click:Connect(function()
                    selected = tostring(opt)
                    header.Text = "v  " .. label .. ":  " .. selected
                    open = false
                    dropdownFrame.Visible = false
                    container.Size = UDim2.new(1, 0, 0, 36)
                    if callback then pcall(callback, selected) end
                end)
            end
            
            dropdownFrame.Size = UDim2.new(1, 0, 0, #options * 30 + 8)
        end
        
        buildOptions()
        
        header.MouseButton1Click:Connect(function()
            open = not open
            dropdownFrame.Visible = open
            container.Size = open and UDim2.new(1, 0, 0, 36 + dropdownFrame.Size.Y.Offset + 4) or UDim2.new(1, 0, 0, 36)
        end)
        
        if callback then pcall(callback, selected) end
        
        return {
            Refresh = function(_, newOpts)
                options = newOpts or {}
                selected = tostring(options[1] or "")
                header.Text = "v  " .. label .. ":  " .. selected
                buildOptions()
            end
        }
    end
    
    -- TextBox
    function TabObj:TextBox(label, callback, clearOnFocus)
        local container = self:CreateContainer(56)
        
        Create("TextLabel", {
            Size = UDim2.new(1, -12, 0, 20),
            Position = UDim2.new(0, 6, 0, 4),
            BackgroundTransparency = 1,
            Text = label,
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = container
        })
        
        local box = Create("TextBox", {
            Size = UDim2.new(1, -16, 0, 24),
            Position = UDim2.new(0, 8, 0, 26),
            BackgroundColor3 = C.bg3,
            BorderSizePixel = 0,
            Text = "",
            PlaceholderText = "Digite aqui...",
            PlaceholderColor3 = C.txt3,
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClearTextOnFocus = clearOnFocus == true,
