    })
    
    self:Connect(self.Hitbox.MouseButton1Click, function()
        if self.IsOpen then self:Close() else self:Open() end
    end)
    
    return self
end

function DropdownComponent:Open()
    if self.IsOpen then return end
    NagaxLib.Overlay.Init()
    NagaxLib.Overlay.RegisterDropdown(self)
    
    self.IsOpen = true
    Utils.Tween(self.Icon, {Rotation = 180}, 0.2)
    
    -- Create Dropdown Frame in Overlay
    local listSize = math.min(#self.Options * 28 + 8, 150)
    
    self.Frame = Utils.Create("Frame", {
        Name = "DropdownList",
        Size = UDim2.new(0, self.Instance.AbsoluteSize.X, 0, 0),
        Position = UDim2.new(0, self.Instance.AbsolutePosition.X, 0, self.Instance.AbsolutePosition.Y + self.Instance.AbsoluteSize.Y + 4),
        BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        ZIndex = Config.ZIndex.Dropdown,
        Parent = NagaxLib.Overlay.Gui
    })
    Utils.RoundCorners(self.Frame, 6)
    Utils.AddStroke(self.Frame, 1, NagaxLib.Theme.Colors.Border)
    
    local scroll = Utils.Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -4),
        Position = UDim2.new(0, 0, 0, 2),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = NagaxLib.Theme.Colors.Accent.Dark,
        CanvasSize = UDim2.new(0, 0, 0, #self.Options * 28),
        Parent = self.Frame
    })
    
    Utils.Create("UIListLayout", {
        Padding = UDim.new(0, 2),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        Parent = scroll
    })
    
    for _, opt in ipairs(self.Options) do
        local btn = Utils.Create("TextButton", {
            Size = UDim2.new(0.95, 0, 0, 26),
            BackgroundColor3 = opt == self.Selected and NagaxLib.Theme.Colors.Accent.Primary or NagaxLib.Theme.Colors.Background.Quaternary,
            BorderSizePixel = 0,
            Text = tostring(opt),
            TextColor3 = opt == self.Selected and NagaxLib.Theme.Colors.Text.Primary or NagaxLib.Theme.Colors.Text.Secondary,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            AutoButtonColor = false,
            Parent = scroll
        })
        Utils.RoundCorners(btn, 4)
        
        btn.MouseButton1Click:Connect(function()
            self:Set(opt)
            self:Close()
        end)
    end
    
    Utils.Tween(self.Frame, {Size = UDim2.new(0, self.Instance.AbsoluteSize.X, 0, listSize)}, 0.2)
end

function DropdownComponent:Close()
    if not self.IsOpen then return end
    self.IsOpen = false
    Utils.Tween(self.Icon, {Rotation = 0}, 0.2)
    
    if self.Frame then
        local frame = self.Frame
        Utils.Tween(frame, {Size = UDim2.new(0, frame.Size.X.Offset, 0, 0)}, 0.2, function()
            frame:Destroy()
        end)
        self.Frame = nil
    end
    NagaxLib.Overlay.ClearDropdown()
end

function DropdownComponent:Set(value)
    self.Selected = value
    self.SelectionLabel.Text = tostring(value)
    if self.Callback then
        task.spawn(function()
            pcall(self.Callback, value)
        end)
    end
end

