-- ── Sistema de tabs ───────────────────────────────────────────
local tabs      = {}
local activeTab = nil

local function selectTab(t)
    if activeTab == t then return end
    if activeTab then
        tween(activeTab._btn, {BackgroundColor3=C.bg3})
        activeTab._btn.TextColor3 = C.txt2
        activeTab._btn:SetAttribute("active", false)
        activeTab._scroll.Visible = false
    end
    activeTab                    = t
    tween(t._btn, {BackgroundColor3=C.acc})
    t._btn.TextColor3            = C.white
    t._btn:SetAttribute("active", true)
    t._scroll.Visible            = true
end

-- ── Criacao de Tab ────────────────────────────────────────────
function NagaxLib:Tab(name)

    -- Botao na sidebar (sem emoji)
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(1,0,0,32)
    btn.BackgroundColor3 = C.bg3
    btn.BorderSizePixel  = 0
    btn.Text             = name
    btn.TextColor3       = C.txt2
    btn.TextSize         = 11
    btn.Font             = Enum.Font.Gotham
    btn.TextXAlignment   = Enum.TextXAlignment.Left
    btn.AutoButtonColor  = false
    btn.LayoutOrder      = #tabs + 1
    btn.Parent           = sidebar
    corner(btn, 7)

    local btnPad = Instance.new("UIPadding")
    btnPad.PaddingLeft = UDim.new(0,10)
    btnPad.Parent      = btn

    btn.MouseEnter:Connect(function()
        if not (activeTab and activeTab._btn == btn) then
            tween(btn,{BackgroundColor3=C.bg4})
        end
    end)
    btn.MouseLeave:Connect(function()
        if not (activeTab and activeTab._btn == btn) then
            tween(btn,{BackgroundColor3=C.bg3})
        end
    end)

    -- ScrollingFrame do conteudo
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name                 = "Scroll_"..name
    scroll.Size                 = UDim2.new(1,0,1,0)
    scroll.BackgroundTransparency=1
    scroll.BorderSizePixel      = 0
    scroll.ScrollBarThickness   = 3
    scroll.ScrollBarImageColor3 = C.acc3
    scroll.CanvasSize           = UDim2.new(0,0,0,0)
    scroll.AutomaticCanvasSize  = Enum.AutomaticSize.Y
    scroll.ElasticBehavior      = Enum.ElasticBehavior.Never
    scroll.Visible              = false
    scroll.Parent               = mainPanel

    local scrollPad = Instance.new("UIPadding")
    scrollPad.PaddingTop    = UDim.new(0,8)
    scrollPad.PaddingBottom = UDim.new(0,8)
    scrollPad.PaddingLeft   = UDim.new(0,8)
    scrollPad.PaddingRight  = UDim.new(0,10)
    scrollPad.Parent        = scroll

    local scrollList = Instance.new("UIListLayout")
    scrollList.FillDirection       = Enum.FillDirection.Vertical
    scrollList.Padding             = UDim.new(0,4)
    scrollList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    scrollList.VerticalAlignment   = Enum.VerticalAlignment.Top
    scrollList.SortOrder           = Enum.SortOrder.LayoutOrder
    scrollList.Parent              = scroll

    local tabObj = {_btn=btn, _scroll=scroll, _order=0}

    local function nextOrder()
        tabObj._order = tabObj._order + 1
        return tabObj._order
    end

    -- ── Row base ──────────────────────────────────────────────
    local function makeRow(h, transparent)
        local f = Instance.new("Frame")
        f.Size                  = UDim2.new(1,0,0,h or 34)
        f.BackgroundColor3      = C.bg4
        f.BackgroundTransparency= transparent and 1 or 0
        f.BorderSizePixel       = 0
        f.LayoutOrder           = nextOrder()
        f.ClipsDescendants      = false
        f.Parent                = scroll
        corner(f, 7)
        if not transparent then
            stroke(f, 1, C.bdr)
        end
        return f
    end

    -- ── SEPARATOR ────────────────────────────────────────────
    function tabObj:Seperator(text)
        local f = Instance.new("Frame")
        f.Size                  = UDim2.new(1,0,0,26)
        f.BackgroundTransparency= 1
        f.BorderSizePixel       = 0
        f.LayoutOrder           = nextOrder()
        f.Parent                = scroll

        local lineL = Instance.new("Frame")
