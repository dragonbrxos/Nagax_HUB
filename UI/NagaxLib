    Colors = {
        Background = {
            Primary = Color3.fromRGB(13, 13, 20),
            Secondary = Color3.fromRGB(19, 19, 31),
            Tertiary = Color3.fromRGB(26, 26, 42),
            Quaternary = Color3.fromRGB(34, 34, 53),
            Hover = Color3.fromRGB(42, 42, 66)
        },
        Accent = {
            Primary = Color3.fromRGB(108, 79, 255),
            Secondary = Color3.fromRGB(139, 111, 255),
            Dark = Color3.fromRGB(74, 53, 204),
            Gradient = {Color3.fromRGB(108, 79, 255), Color3.fromRGB(139, 111, 255)}
        },
        State = {
            On = Color3.fromRGB(45, 190, 90),
            Off = Color3.fromRGB(42, 42, 66),
            Error = Color3.fromRGB(200, 50, 50),
            Warning = Color3.fromRGB(245, 158, 11)
        },
        Text = {
            Primary = Color3.fromRGB(232, 232, 255),
            Secondary = Color3.fromRGB(144, 144, 184),
            Tertiary = Color3.fromRGB(90, 90, 122),
            Shadow = Color3.fromRGB(0, 0, 0)
        },
        Border = Color3.fromRGB(42, 42, 66)
    },
    
    Set = function(category, key, color)
        if NagaxLib.Theme.Colors[category] and NagaxLib.Theme.Colors[category][key] then
            NagaxLib.Theme.Colors[category][key] = color
            NagaxLib.Theme._propagate(category, key, color)
        end
    end,
    
