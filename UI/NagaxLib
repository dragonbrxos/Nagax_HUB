        },
        Border = Color3.fromRGB(42, 42, 66)
    },
    
    -- Atualiza cor e propaga para todos os elementos registrados
    Set = function(category, key, color)
        if NagaxLib.Theme.Colors[category] and NagaxLib.Theme.Colors[category][key] then
            NagaxLib.Theme.Colors[category][key] = color
            NagaxLib.Theme._propagate(category, key, color)
        end
