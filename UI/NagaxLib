        f.BackgroundTransparency= 1
        f.BorderSizePixel       = 0
        f.LayoutOrder           = nextOrder()
        f.Parent                = scroll

        local ln = Instance.new("Frame")
        ln.Size             = UDim2.new(1,-10,0,1)
