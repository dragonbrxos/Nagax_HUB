    -- Atualiza posição quando a janela move (listener do render step otimizado)
    self:Connect(Services.RunService.Heartbeat, function()
        if self.IsOpen and self.Instance and self.Instance.Parent then
            local absPos = self.Instance.AbsolutePosition
            local absSize = self.Instance.AbsoluteSize
            
            -- Só atualiza se mudou significativamente (evita jitter)
            local currentPos = self.FloatFrame.Position
            local targetX = absPos.X
            local targetY = absPos.Y + absSize.Y
            
            if math.abs(currentPos.X.Offset - targetX) > 1 or 
               math.abs(currentPos.Y.Offset - targetY) > 1 then
                self.FloatFrame.Position = UDim2.new(0, targetX, 0, targetY)
                self.FloatFrame.Size = UDim2.new(0, absSize.X, 0, self.FloatFrame.Size.Y.Offset)
            end
        end
    end)
    
    if self.Callback then
        task.spawn(self.Callback, self.Selected)
    end
    
    return self
end

function DropdownComponent:BuildOptions()
    -- Limpa existentes
    for _, child in ipairs(self.Scroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    for _, opt in ipairs(self.Options) do
        local btn = Utils.Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary,
            BorderSizePixel = 0,
            Text = tostring(opt),
            TextColor3 = NagaxLib.Theme.Colors.Text.Primary,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
            Parent = self.Scroll
        })
        Utils.RoundCorners(btn, 5)
        
        Utils.Create("UIPadding", {
            PaddingLeft = UDim.new(0, 8),
            Parent = btn
        })
        
        -- Hover
        local enterConn = btn.MouseEnter:Connect(function()
            Utils.Tween(btn, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Quaternary}, 0.1)
        end)
        local leaveConn = btn.MouseLeave:Connect(function()
            Utils.Tween(btn, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary}, 0.1)
        end)
        
        -- Seleção
        local clickConn = btn.MouseButton1Click:Connect(function()
            self:SetValue(tostring(opt))
            self:Close()
        end)
        
        table.insert(self._connections, enterConn)
        table.insert(self._connections, leaveConn)
        table.insert(self._connections, clickConn)
    end
    
    -- Calcula altura máxima (max 5 itens visíveis)
    local itemHeight = 28
    local maxHeight = math.min(#self.Options * itemHeight + 6, 5 * itemHeight + 6)
    self.TargetHeight = maxHeight
end

function DropdownComponent:Toggle()
    if self.IsOpen then
        self:Close()
    else
        self:Open()
    end
end

function DropdownComponent:Open()
    if self.IsOpen then return end
    
    -- Fecha outros dropdowns abertos
    NagaxLib.Overlay.RegisterDropdown(self)
    
    self.IsOpen = true
    self.FloatFrame.Visible = true
    self.FloatFrame.Size = UDim2.new(0, self.FloatFrame.Size.X.Offset, 0, 0)
    
    -- Animação de abertura
    Utils.Tween(self.FloatFrame, {Size = UDim2.new(0, self.FloatFrame.Size.X.Offset, 0, self.TargetHeight)}, 0.2)
    Utils.Tween(self.Arrow, {Rotation = 180}, 0.2)
end

function DropdownComponent:Close()
    if not self.IsOpen then return end
    
    self.IsOpen = false
    Utils.Tween(self.FloatFrame, {Size = UDim2.new(0, self.FloatFrame.Size.X.Offset, 0, 0)}, 0.2, function()
        if not self.IsOpen then
            self.FloatFrame.Visible = false
        end
    end)
    Utils.Tween(self.Arrow, {Rotation = 0}, 0.2)
    
    NagaxLib.Overlay.ClearDropdown()
end

function DropdownComponent:SetValue(value)
    if table.find(self.Options, value) then
        self.Selected = value
        self.Header.Text = "v  " .. self.LabelText .. ":  " .. self.Selected
        if self.Callback then
            self.Callback(self.Selected)
        end
    end
end

function DropdownComponent:GetValue()
    return self.Selected
end

function DropdownComponent:Refresh(newOptions, keepSelected)
    self.Options = newOptions or {}
    if not keepSelected or not table.find(self.Options, self.Selected) then
        self.Selected = tostring(self.Options[1] or "")
    end
    self.Header.Text = "v  " .. self.LabelText .. ":  " .. self.Selected
    self:BuildOptions()
    if self.Callback then
        self.Callback(self.Selected)
    end
end

function DropdownComponent:Destroy()
    self:Close()
    if self.FloatFrame then
        self.FloatFrame:Destroy()
    end
    ComponentBase.Destroy(self)
end

