    -- Drag System (Otimizado)
    if self.DragEnabled then
        local dragging = false
        local dragStart, startPos
        
        self.Header.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or 
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = self.Main.Position
            end
        end)
        
        Services.UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                           input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                self.Main.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end)
        
        Services.UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or 
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end
    
    -- Toggle visibilidade com RightShift
    Services.UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.RightShift then
            self.Gui.Enabled = not self.Gui.Enabled
        end
    end)
    
    table.insert(NagaxLib._windows, self)
    return self
end

function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end
    
    if self.ActiveTab then
        Utils.Tween(self.ActiveTab.Button, {BackgroundColor3 = NagaxLib.Theme.Colors.Background.Tertiary}, 0.15)
        self.ActiveTab.Button.TextColor3 = NagaxLib.Theme.Colors.Text.Secondary
        self.ActiveTab.Scroll.Visible = false
    end
    
    self.ActiveTab = tab
    Utils.Tween(tab.Button, {BackgroundColor3 = NagaxLib.Theme.Colors.Accent.Primary}, 0.15)
    tab.Button.TextColor3 = NagaxLib.Theme.Colors.Text.Primary
    tab.Scroll.Visible = true
end

function Window:Tab(name)
    local tab = TabSystem:Create(self, name)
    table.insert(self.Tabs, tab)
    
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    
    return tab
end

function Window:SetScale(scale)
    scale = math.clamp(scale, Config.Window.MinScale, Config.Window.MaxScale)
    self.Scale = scale
    local newW = math.floor(Config.Window.Width * scale)
    local newH = math.floor(Config.Window.Height * scale)
    self.Main.Size = UDim2.new(0, newW, 0, newH)
    self.Main.Position = UDim2.new(0.5, -newW/2, 0.5, -newH/2)
end

function Window:Init()
    -- Método placeholder para compatibilidade
end

NagaxLib.MakeTab = function(window, name) 
    return window:Tab(name) 
end

-- Exportação
return NagaxLib
