        })
        CreateCorner(optFrame, 6)
        CreateStroke(optFrame, 1, C.bdr)
        
        SafeCreate("UIPadding", {
            PaddingTop = UDim.new(0, 3),
            PaddingBottom = UDim.new(0, 3),
            PaddingLeft = UDim.new(0, 3),
            PaddingRight = UDim.new(0, 3),
            Parent = optFrame
        })
        
        local optList = SafeCreate("UIListLayout", {
            FillDirection = Enum.FillDirection.Vertical,
            Padding = UDim.new(0, 2),
            Parent = optFrame
        })
        
        local function BuildOpts(opts)
            -- Limpa opções antigas
            for _, ch in ipairs(optFrame:GetChildren()) do
                if ch:IsA("TextButton") then
                    ch:Destroy()
                end
            end
            
            for _, opt in ipairs(opts) do
                local ob = SafeCreate("TextButton", {
                    Size = UDim2.new(1, 0, 0, 26),
                    BackgroundColor3 = C.bg3,
                    BorderSizePixel = 0,
                    Text = tostring(opt),
                    TextColor3 = C.txt,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    AutoButtonColor = false,
                    ZIndex = 16,
                    Parent = optFrame
                })
                CreateCorner(ob, 5)
                
                SafeCreate("UIPadding", {
                    PaddingLeft = UDim.new(0, 8),
                    Parent = ob
                })
                
                ob.MouseEnter:Connect(function()
                    Tween(ob, {BackgroundColor3 = C.bg4}, 0.15)
                end)
                ob.MouseLeave:Connect(function()
                    Tween(ob, {BackgroundColor3 = C.bg3}, 0.15)
                end)
                
                ob.MouseButton1Click:Connect(function()
                    selected = tostring(opt)
                    hdrDD.Text = "v  " .. (labelText or "") .. ":  " .. selected
                    open = false
                    optFrame.Visible = false
                    container.Size = UDim2.new(1, 0, 0, 34)
                    
                    if callback then
                        local success, err = pcall(callback, selected)
                        if not success then
                            warn("[NagaxLib] Dropdown callback error: " .. tostring(err))
                        end
                    end
                end)
            end
            
            optFrame.Size = UDim2.new(1, 0, 0, #opts * 28 + 6)
        end
        
        BuildOpts(options)
        
        hdrDD.MouseButton1Click:Connect(function()
            open = not open
            optFrame.Visible = open
            container.Size = open 
                and UDim2.new(1, 0, 0, 34 + #options * 28 + 6)
                or UDim2.new(1, 0, 0, 34)
        end)
        
        if callback then
            task.spawn(function()
                local success, err = pcall(callback, selected)
                if not success then
                    warn("[NagaxLib] Dropdown initial callback error: " .. tostring(err))
                end
            end)
        end
        
        return {
            Refresh = function(_, newOpts)
                options = newOpts or {}
                selected = tostring(options[1] or "")
                hdrDD.Text = "v  " .. (labelText or "") .. ":  " .. selected
                BuildOpts(options)
                if callback then
                    pcall(callback, selected)
                end
            end,
            Clear = function(_)
                options = {}
                for _, ch in ipairs(optFrame:GetChildren()) do
                    if ch:IsA("TextButton") then
                        ch:Destroy()
                    end
                end
                container.Size = UDim2.new(1, 0, 0, 34)
                optFrame.Visible = false
                open = false
            end,
            Add = function(_, opt)
                table.insert(options, opt)
                BuildOpts(options)
            end,
            GetSelected = function()
                return selected
            end
        }
    end
    
    -- TEXTBOX
    function Tab:TextBox(labelText, callback, clearOnFocus)
        local row = Tab:CreateRow(50)
        
        local lbl = SafeCreate("TextLabel", {
            Size = UDim2.new(1, -10, 0, 18),
            Position = UDim2.new(0, 8, 0, 3),
            BackgroundTransparency = 1,
            Text = labelText or "",
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row
        })
        
        local box = SafeCreate("TextBox", {
            Size = UDim2.new(1, -16, 0, 22),
            Position = UDim2.new(0, 8, 0, 24),
            BackgroundColor3 = C.bg3,
            BorderSizePixel = 0,
            Text = "",
            PlaceholderText = "Digite aqui...",
            PlaceholderColor3 = C.txt3,
            TextColor3 = C.txt,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClearTextOnFocus = (clearOnFocus == true),
            ZIndex = 3,
            Parent = row
        })
        CreateCorner(box, 5)
        CreateStroke(box, 1, C.bdr)
        
        box.FocusLost:Connect(function(enterPressed)
            if enterPressed and callback then
                local success, err = pcall(callback, box.Text)
                if not success then
                    warn("[NagaxLib] TextBox callback error: " .. tostring(err))
                end
            end
        end)
    end
    
    -- Sistema de seleção de Tab
    function self:SelectTab(tab)
        if self.ActiveTab == tab then return end
        
        if self.ActiveTab then
            Tween(self.ActiveTab.Button, {BackgroundColor3 = C.bg3}, 0.2)
            self.ActiveTab.Button.TextColor3 = C.txt2
            self.ActiveTab.Button:SetAttribute("Active", false)
            self.ActiveTab.Scroll.Visible = false
        end
        
        self.ActiveTab = tab
        Tween(tab.Button, {BackgroundColor3 = C.acc}, 0.2)
        tab.Button.TextColor3 = C.white
        tab.Button:SetAttribute("Active", true)
        tab.Scroll.Visible = true
    end
    
    btn.MouseButton1Click:Connect(function()
        self:SelectTab(Tab)
    end)
    
    -- Hover effects
    btn.MouseEnter:Connect(function()
        if self.ActiveTab ~= Tab then
            Tween(btn, {BackgroundColor3 = C.bg4}, 0.15)
        end
    end)
    btn.MouseLeave:Connect(function()
        if self.ActiveTab ~= Tab then
            Tween(btn, {BackgroundColor3 = C.bg3}, 0.15)
        end
    end)
    
    table.insert(self.Tabs, Tab)
    
    -- Auto-select primeira tab
    if #self.Tabs == 1 then
        task.spawn(function()
            wait(0.1)
            self:SelectTab(Tab)
        end)
    end
    
    return Tab
end

-- Função de inicialização segura
function NagaxLib:Init()
    -- Verifica se tudo foi criado corretamente
    if not self.ScreenGui or not self.MainFrame then
        warn("[NagaxLib] Falha na inicialização: elementos principais não criados")
        return false
    end
    
    print("[NagaxLib v7] Interface inicializada com sucesso")
    return true
end

return NagaxLib
