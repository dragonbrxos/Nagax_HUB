            {Color3.fromRGB(45, 156, 255), Color3.fromRGB(90, 182, 255), Color3.fromRGB(28, 108, 200)},
            {Color3.fromRGB(45, 190, 90), Color3.fromRGB(80, 210, 120), Color3.fromRGB(28, 138, 58)},
            {Color3.fromRGB(230, 61, 90), Color3.fromRGB(255, 95, 120), Color3.fromRGB(176, 38, 60)},
            {Color3.fromRGB(245, 158, 11), Color3.fromRGB(251, 191, 36), Color3.fromRGB(180, 116, 0)},
            {Color3.fromRGB(6, 182, 212), Color3.fromRGB(34, 211, 238), Color3.fromRGB(4, 130, 155)},
        }
        
        for _, colorSet in ipairs(colors) do
            local btn = SafeCreate("TextButton", {
                Size = UDim2.new(0, 24, 0, 24),
                BackgroundColor3 = colorSet[1],
                BorderSizePixel = 0,
                Text = "",
                AutoButtonColor = false,
