    -- Sistema de Drag Aprimorado
    local Dragging = false
    local DragStart = nil
    local StartPos = nil
    
    function Window:SetDraggable(enabled)
        Window.DragEnabled = enabled
        Window.MainFrame.Active = enabled
        if Window.DragStatus then
            Window.DragStatus.Text = "Drag: " .. (enabled and "ON" or "OFF")
        end
    end
    
    Window.MainFrame.InputBegan:Connect(function(input)
        if not Window.DragEnabled then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = input.Position
            StartPos = Window.MainFrame.Position
        end
    end)
    
    Window.MainFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            Dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if not Dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - DragStart
            Window.MainFrame.Position = UDim2.new(
                StartPos.X.Scale, StartPos.X.Offset + delta.X,
                StartPos.Y.Scale, StartPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Toggle com RightShift
