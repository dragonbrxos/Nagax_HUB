-- Utilitários robustos
local function SafeCreate(className, properties)
    local success, obj = pcall(function()
        local obj = Instance.new(className)
        if properties then
            for prop, value in pairs(properties) do
                obj[prop] = value
            end
        end
        return obj
    end)
    
    if success then
        return obj
    else
        warn("[NagaxLib] Falha ao criar " .. className .. ": " .. tostring(obj))
        return nil
    end
end

local function SafeParent(obj, parent)
    if not obj then return false end
    local success, err = pcall(function()
        obj.Parent = parent
    end)
    if not success then
        warn("[NagaxLib] Falha ao setar parent: " .. tostring(err))
        return false
    end
    return true
end

local function CreateCorner(parent, radius)
    local corner = SafeCreate("UICorner", {
        CornerRadius = UDim.new(0, radius or 6),
        Parent = parent
    })
    return corner
end

local function CreateStroke(parent, thickness, color)
    local stroke = SafeCreate("UIStroke", {
        Thickness = thickness or 1,
        Color = color or C.bdr,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = parent
    })
    return stroke
end

local function Tween(obj, props, duration, style, direction)
    if not obj or not obj.Parent then return nil end
    local success, tween = pcall(function()
        local info = TweenInfo.new(
            duration or 0.15,
            style or Enum.EasingStyle.Quad,
            direction or Enum.EasingDirection.Out
        )
        return TweenService:Create(obj, info, props)
    end)
    
    if success and tween then
        tween:Play()
        return tween
    end
    return nil
end

