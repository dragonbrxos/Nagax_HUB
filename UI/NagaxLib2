                    self.SidebarBorder.BackgroundColor3 = C.acc3
                end
                if self.Header then
                    local line = self.Header:FindFirstChild("Frame") -- hdrLine
                    if line then
                        line.BackgroundColor3 = C.acc3
                    end
                end
                if self.CustomBtn then
                    self.CustomBtn.TextColor3 = C.acc2
                end
                
                -- Atualiza tabs ativas
                for _, tab in ipairs(self.Tabs) do
                    if tab.Button and tab.Button:GetAttribute("Active") then
                        tab.Button.BackgroundColor3 = C.acc
                    end
                end
            end)
